---
const currentYear = new Date().getFullYear();
---

<footer class="site-footer" transition:persist>
  <div class="container footer-grid">
    <div class="footer-brand">
      <p class="footer-kicker">FlowOFF</p>
      <h2>Infraestrutura digital orientada a conversao.</h2>
      <p>
        Flowoff Marketing e Assessoria Digital LTDA, CNPJ
        43.376.355/0001-92. Estrategia, interfaces e ativos digitais para
        captar demanda com mais clareza operacional.
      </p>
    </div>

    <nav class="footer-column" aria-label="Paginas institucionais">
      <h3>Institucional</h3>
      <a href="/">Inicio</a>
      <a href="/privacidade">Privacidade</a>
      <a href="/termos">Termos de uso</a>
      <a href="/cookies">Cookies</a>
      <a href="/seguranca">Seguranca de dados</a>
    </nav>

    <div class="footer-column">
      <h3>Presenca</h3>
      <a href="https://instagram.com/neoflowoff.eth" target="_blank" rel="noreferrer">
        Instagram: @neoflowoff.eth
      </a>
      <a
        href="https://www.linkedin.com/company/neoflowoff/"
        target="_blank"
        rel="noreferrer"
      >
        LinkedIn: /company/neoflowoff/
      </a>
    </div>
  </div>

  <div class="container footer-bottom">
    <p>© {currentYear} Flowoff Marketing e Assessoria Digital LTDA.</p>
    <p>CNPJ 43.376.355/0001-92.</p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    padding: 1.35rem 0 1.7rem;
    border-top: 1px solid var(--border-subtle);
    background:
      linear-gradient(
        180deg,
        rgba(7, 12, 20, 0.16) 0%,
        rgba(4, 8, 14, 0.92) 100%
      ),
      rgba(4, 8, 14, 0.86);
    backdrop-filter: blur(22px) saturate(1.2);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr 0.8fr;
    gap: 1.1rem;
    padding: 1rem 0 1.1rem;
  }

  .footer-brand h2 {
    max-width: 14ch;
    margin-bottom: 0.7rem;
    font-size: clamp(1.1rem, 2vw, 1.6rem);
  }

  .footer-brand p {
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .footer-kicker {
    margin-bottom: 0.55rem;
    color: #91f2ff;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 800;
    font-size: 0.68rem;
  }

  .footer-column {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }

  .footer-column h3 {
    margin-bottom: 0.15rem;
    color: #eef8ff;
    font-size: 0.8rem;
    letter-spacing: 0.04em;
  }

  .footer-column a {
    color: var(--text-2);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    width: fit-content;
    max-width: 100%;
    padding: 0 0.7rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.035);
    border: 1px solid var(--border-subtle);
    font-size: 0.82rem;
    transition:
      color 160ms var(--ease-out),
      background 160ms var(--ease-out);
  }

  .footer-column a:active { opacity: 0.75; }

  @media (hover: hover) and (pointer: fine) {
    .footer-column a:hover {
      color: #061018;
      background: rgba(145, 242, 255, 0.92);
    }
  }

  .footer-bottom {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.65rem;
    padding-top: 0.9rem;
    border-top: 1px solid rgba(159, 241, 255, 0.05);
  }

  .footer-bottom p {
    margin: 0;
    color: var(--text-4);
    font-size: 0.76rem;
  }

  /* ─── Responsive ─── */
  @media (max-width: 980px) {
    .footer-grid {
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }
  }

  @media (max-width: 640px) {
    .site-footer {
      padding: 1rem 0 calc(env(safe-area-inset-bottom, 0px) + 1.4rem);
    }

    .footer-grid { padding: 0.75rem 0 0.9rem; }

    .footer-brand h2 {
      font-size: 1rem;
      max-width: 16ch;
    }

    .footer-brand p { font-size: 0.82rem; }

    .footer-column a {
      min-height: 30px;
      padding: 0 0.6rem;
      font-size: 0.76rem;
    }

    .footer-bottom {
      flex-direction: column;
      gap: 0.35rem;
    }
  }
</style>
