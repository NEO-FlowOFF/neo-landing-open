---
import { Image } from "astro:assets";
import logo from "../assets/neoflowoff_logo.png";
import EngineeringBadge from "./EngineeringBadge.astro";
const year = new Date().getFullYear();
---

<footer class="ft" transition:persist>
  <!-- ── Editorial header ── -->
  <div class="ft-top">
    <div class="ft-logo-wrap">
      <Image
        class="ft-logo"
        src={logo}
        alt="NEØ FlowOFF"
        loading="lazy"
        widths={[80, 140]}
        sizes="56px"
      />
    </div>
    <div class="ft-rule" aria-hidden="true"></div>
  </div>

  <!-- ── Brand statement ── -->
  <div class="ft-statement container">
    <p class="ft-eyebrow">Infraestrutura digital</p>
    <h2 class="ft-headline" aria-label="Estrutura que opera vendas.">
      Estrutura que<br />opera vendas.
    </h2>
  </div>

  <!-- ── Navigation ── -->
  <div class="ft-nav-wrap container">
    <div class="ft-rule-thin" aria-hidden="true"></div>
    <nav class="ft-nav" aria-label="Páginas institucionais">
      <a href="/" class="ft-link">Início</a>
      <span class="ft-sep" aria-hidden="true">·</span>
      <a href="/privacidade" class="ft-link">Privacidade</a>
      <span class="ft-sep" aria-hidden="true">·</span>
      <a href="/termos" class="ft-link">Termos</a>
      <span class="ft-sep" aria-hidden="true">·</span>
      <a href="/cookies" class="ft-link">Cookies</a>
      <span class="ft-sep" aria-hidden="true">·</span>
      <a href="/seguranca" class="ft-link">Segurança de dados</a>
    </nav>
    <div class="ft-rule-thin" aria-hidden="true"></div>
  </div>

  <!-- ── Presence ── -->
  <div class="ft-presence container">
    <a
      class="ft-social"
      href="https://instagram.com/neoflowoff.eth"
      target="_blank"
      rel="noreferrer"
      aria-label="Instagram da NEØ FlowOFF"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path
          d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
          x1="17.5"
          y1="6.5"
          x2="17.51"
          y2="6.5"></line>
      </svg>
      @neoflowoff.eth
    </a>
    <a
      class="ft-social"
      href="https://www.linkedin.com/company/neoflowoff/"
      target="_blank"
      rel="noreferrer"
      aria-label="LinkedIn da NEØ FlowOFF"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path
          d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
        ></path><rect x="2" y="9" width="4" height="12"></rect><circle
          cx="4"
          cy="4"
          r="2"></circle>
      </svg>
      /company/neoflowoff
    </a>
    <a
      class="ft-social"
      href="https://www.facebook.com/neoflowoff.eth/"
      target="_blank"
      rel="noreferrer"
      aria-label="Facebook da NEØ FlowOFF"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
      </svg>
      /neoflowoff.eth
    </a>
    <a
      class="ft-social"
      href="https://www.youtube.com/@agenciaflowoff"
      target="_blank"
      rel="noreferrer"
      aria-label="YouTube da NEØ FlowOFF"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46A2.78 2.78 0 0 0 1.46 6.42 29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58 2.78 2.78 0 0 0 1.95 1.96C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.96A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"></path><polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"></polygon>
      </svg>
      @agenciaflowoff
    </a>
    <a
      class="ft-social"
      href="https://x.com/neoflw_on_chain"
      target="_blank"
      rel="noreferrer"
      aria-label="X (Twitter) da NEØ FlowOFF"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="currentColor"
        stroke="none"
        aria-hidden="true"
      >
        <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
      </svg>
      @neoflw_on_chain
    </a>
    <a
      class="ft-social"
      href="https://www.threads.com/@neoflowoff.eth"
      target="_blank"
      rel="noreferrer"
      aria-label="Threads da NEØ FlowOFF"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="currentColor"
        stroke="none"
        aria-hidden="true"
      >
        <path d="M12.186 24h-.007c-3.581-.024-6.334-1.205-8.184-3.509C2.35 18.44 1.5 15.586 1.472 12.01v-.017c.03-3.579.879-6.43 2.525-8.482C5.845 1.205 8.6.024 12.18 0h.014c2.746.02 5.043.725 6.826 2.098 1.677 1.29 2.858 3.13 3.509 5.467l-2.04.569c-1.104-3.96-3.898-5.984-8.304-6.015-2.91.022-5.11.936-6.54 2.717C4.307 6.504 3.616 8.914 3.589 12c.027 3.086.718 5.496 2.057 7.164 1.43 1.783 3.631 2.698 6.54 2.717 2.623-.02 4.358-.631 5.8-2.045 1.647-1.613 1.618-3.593 1.09-4.798-.31-.71-.873-1.3-1.634-1.75-.192 1.352-.622 2.446-1.284 3.272-.886 1.102-2.14 1.704-3.73 1.79-1.202.065-2.361-.218-3.259-.801-1.063-.689-1.685-1.74-1.752-2.964-.065-1.19.408-2.285 1.33-3.082.88-.76 2.119-1.207 3.583-1.291a13.853 13.853 0 0 1 3.02.142c-.126-.742-.375-1.332-.75-1.757-.513-.583-1.313-.877-2.379-.873h-.02c-.834.01-1.998.285-2.748 1.374l-1.667-1.194c.981-1.454 2.597-2.246 4.422-2.252h.032c3.359.016 5.365 2.108 5.466 5.745.499.26.898.55 1.219.878 1.048 1.074 1.61 2.567 1.482 4.288-.175 2.352-1.357 4.303-3.288 5.283-1.51.772-3.174 1.173-5.01 1.173z"></path>
      </svg>
      @neoflowoff.eth
    </a>
  </div>

  <!-- ── Legal bottom ── -->
  <div class="ft-bottom container">
    <div class="ft-engineering">
      <EngineeringBadge />
    </div>
    <div class="ft-rule-thin" aria-hidden="true"></div>
    <div class="ft-legal">
      <span class="ft-legal-name"
        >Flowoff Marketing e Assessoria Digital LTDA</span
      >
      <span class="ft-legal-detail">CNPJ 43.376.355/0001-92</span>
      <span class="ft-legal-copy">© {year} NEØ FlowOFF — Goiânia, Brasil</span>
    </div>
  </div>
</footer>

<style>
  /* ── Shell ── */
  .ft {
    position: relative;
    padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 2.4rem);
    overflow: hidden;
  }

  /* faint vignette fade from page content */
  .ft::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 80% 60% at 50% 0%,
        rgba(255, 31, 143, 0.04) 0%,
        transparent 70%
      ),
      linear-gradient(180deg, rgba(6, 10, 18, 0) 0%, rgba(4, 7, 14, 0.98) 100%);
    pointer-events: none;
  }

  /* ── Top block: logo + full-bleed rule ── */
  .ft-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 3rem;
    gap: 1.6rem;
  }

  .ft-logo-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
  }

  /* glow ring behind logo */
  .ft-logo-wrap::before {
    content: "";
    position: absolute;
    inset: -8px;
    border-radius: 999px;
    background: radial-gradient(
      circle,
      rgba(255, 31, 143, 0.18) 0%,
      transparent 70%
    );
    filter: blur(8px);
  }

  .ft-logo {
    position: relative;
    z-index: 1;
    width: 56px;
    object-fit: contain;
    /* compensate transparent PNG padding */
    margin: -10px;
    filter: drop-shadow(0 0 12px rgba(255, 31, 143, 0.35))
      drop-shadow(0 0 28px rgba(255, 31, 143, 0.12));
  }

  /* full-bleed hairline */
  .ft-rule {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 31, 143, 0.22) 30%,
      rgba(255, 255, 255, 0.06) 50%,
      rgba(51, 214, 255, 0.14) 70%,
      transparent 100%
    );
  }

  /* ── Brand statement ── */
  .ft-statement {
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .ft-eyebrow {
    margin: 0 0 0.55rem;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--pink-soft);
  }

  .ft-headline {
    margin: 0;
    font-size: clamp(2rem, 8vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.08;
    color: rgba(255, 255, 255, 0.88);
  }

  /* ── Nav ── */
  .ft-nav-wrap {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    padding-bottom: 1.6rem;
  }

  .ft-rule-thin {
    height: 1px;
    background: rgba(255, 255, 255, 0.055);
  }

  .ft-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.55rem;
  }

  .ft-link {
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.68);
    letter-spacing: 0.01em;
    transition: color 200ms ease;
  }

  .ft-link:active {
    color: rgba(255, 255, 255, 0.82);
  }

  @media (hover: hover) and (pointer: fine) {
    .ft-link:hover {
      color: rgba(255, 255, 255, 0.82);
    }
  }

  .ft-sep {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.5);
    user-select: none;
  }

  /* ── Social presence ── */
  .ft-presence {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-bottom: 2rem;
  }

  .ft-social {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.62);
    letter-spacing: 0.02em;
    transition: color 200ms ease;
  }

  .ft-social svg {
    flex: 0 0 auto;
    opacity: 0.55;
  }

  .ft-social:active {
    color: rgba(255, 255, 255, 0.72);
  }

  @media (hover: hover) and (pointer: fine) {
    .ft-social:hover {
      color: rgba(255, 255, 255, 0.72);
    }
    .ft-social:hover svg {
      opacity: 0.9;
    }
  }

  /* ── Legal bottom ── */
  .ft-bottom {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .ft-engineering {
    display: flex;
    justify-content: flex-start;
    padding-bottom: 0.4rem;
  }

  .ft-legal {
    display: flex;
    flex-direction: column;
    gap: 0.28rem;
  }

  .ft-legal-name {
    font-size: 0.68rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.58);
    letter-spacing: 0.01em;
  }

  .ft-legal-detail,
  .ft-legal-copy {
    font-size: 0.64rem;
    font-family: monospace;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.52);
  }
</style>
