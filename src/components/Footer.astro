---
import { Image } from "astro:assets";
import logo from "../assets/neoflowoff_logo.png";
import EngineeringBadge from "./EngineeringBadge.astro";
const year = new Date().getFullYear();
---

<footer class="ft" transition:persist>
  <!-- ── Editorial header ── -->
  <div class="ft-top">
    <div class="ft-logo-wrap">
      <Image
        class="ft-logo"
        src={logo}
        alt="NEØ FlowOFF"
        loading="lazy"
        widths={[80, 140]}
        sizes="56px"
      />
    </div>
    <div class="ft-rule" aria-hidden="true"></div>
  </div>

  <!-- ── Brand statement ── -->
  <div class="ft-statement container">
    <p class="ft-eyebrow">Infraestrutura digital</p>
    <h2 class="ft-headline">
      Estrutura que<br />opera vendas.
    </h2>
  </div>

  <!-- ── Navigation ── -->
  <div class="ft-nav-wrap container">
    <div class="ft-rule-thin" aria-hidden="true"></div>
    <nav class="ft-nav" aria-label="Páginas institucionais">
      <a href="/" class="ft-link">Início</a>
      <span class="ft-sep" aria-hidden="true">·</span>
      <a href="/privacidade" class="ft-link">Privacidade</a>
      <span class="ft-sep" aria-hidden="true">·</span>
      <a href="/termos" class="ft-link">Termos</a>
      <span class="ft-sep" aria-hidden="true">·</span>
      <a href="/cookies" class="ft-link">Cookies</a>
      <span class="ft-sep" aria-hidden="true">·</span>
      <a href="/seguranca" class="ft-link">Segurança de dados</a>
    </nav>
    <div class="ft-rule-thin" aria-hidden="true"></div>
  </div>

  <!-- ── Presence ── -->
  <div class="ft-presence container">
    <a
      class="ft-social"
      href="https://instagram.com/neoflowoff.eth"
      target="_blank"
      rel="noreferrer"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path
          d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
          x1="17.5"
          y1="6.5"
          x2="17.51"
          y2="6.5"></line>
      </svg>
      @neoflowoff.eth
    </a>
    <a
      class="ft-social"
      href="https://www.linkedin.com/company/neoflowoff/"
      target="_blank"
      rel="noreferrer"
    >
      <svg
        width="14"
        height="14"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
      >
        <path
          d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
        ></path><rect x="2" y="9" width="4" height="12"></rect><circle
          cx="4"
          cy="4"
          r="2"></circle>
      </svg>
      /company/neoflowoff
    </a>
  </div>

  <!-- ── Legal bottom ── -->
  <div class="ft-bottom container">
    <div class="ft-engineering">
      <EngineeringBadge />
    </div>
    <div class="ft-rule-thin" aria-hidden="true"></div>
    <div class="ft-legal">
      <span class="ft-legal-name"
        >Flowoff Marketing e Assessoria Digital LTDA</span
      >
      <span class="ft-legal-detail">CNPJ 43.376.355/0001-92</span>
      <span class="ft-legal-copy">© {year} NEØ FlowOFF — Goiânia, Brasil</span>
    </div>
  </div>
</footer>

<style>
  /* ── Shell ── */
  .ft {
    position: relative;
    padding-bottom: calc(env(safe-area-inset-bottom, 0px) + 2.4rem);
    overflow: hidden;
  }

  /* faint vignette fade from page content */
  .ft::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        ellipse 80% 60% at 50% 0%,
        rgba(255, 31, 143, 0.04) 0%,
        transparent 70%
      ),
      linear-gradient(180deg, rgba(6, 10, 18, 0) 0%, rgba(4, 7, 14, 0.98) 100%);
    pointer-events: none;
  }

  /* ── Top block: logo + full-bleed rule ── */
  .ft-top {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 3rem;
    gap: 1.6rem;
  }

  .ft-logo-wrap {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
  }

  /* glow ring behind logo */
  .ft-logo-wrap::before {
    content: "";
    position: absolute;
    inset: -8px;
    border-radius: 999px;
    background: radial-gradient(
      circle,
      rgba(255, 31, 143, 0.18) 0%,
      transparent 70%
    );
    filter: blur(8px);
  }

  .ft-logo {
    position: relative;
    z-index: 1;
    width: 56px;
    object-fit: contain;
    /* compensate transparent PNG padding */
    margin: -10px;
    filter: drop-shadow(0 0 12px rgba(255, 31, 143, 0.35))
      drop-shadow(0 0 28px rgba(255, 31, 143, 0.12));
  }

  /* full-bleed hairline */
  .ft-rule {
    width: 100%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      rgba(255, 31, 143, 0.22) 30%,
      rgba(255, 255, 255, 0.06) 50%,
      rgba(51, 214, 255, 0.14) 70%,
      transparent 100%
    );
  }

  /* ── Brand statement ── */
  .ft-statement {
    padding-top: 2rem;
    padding-bottom: 2rem;
  }

  .ft-eyebrow {
    margin: 0 0 0.55rem;
    font-size: 0.65rem;
    font-weight: 800;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 31, 143, 0.55);
  }

  .ft-headline {
    margin: 0;
    font-size: clamp(2rem, 8vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 1.08;
    color: rgba(255, 255, 255, 0.88);
  }

  /* ── Nav ── */
  .ft-nav-wrap {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
    padding-bottom: 1.6rem;
  }

  .ft-rule-thin {
    height: 1px;
    background: rgba(255, 255, 255, 0.055);
  }

  .ft-nav {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 0.55rem;
  }

  .ft-link {
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.42);
    letter-spacing: 0.01em;
    transition: color 200ms ease;
  }

  .ft-link:active {
    color: rgba(255, 255, 255, 0.82);
  }

  @media (hover: hover) and (pointer: fine) {
    .ft-link:hover {
      color: rgba(255, 255, 255, 0.82);
    }
  }

  .ft-sep {
    font-size: 0.7rem;
    color: rgba(255, 255, 255, 0.12);
    user-select: none;
  }

  /* ── Social presence ── */
  .ft-presence {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    padding-bottom: 2rem;
  }

  .ft-social {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    text-decoration: none;
    font-size: 0.78rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.32);
    letter-spacing: 0.02em;
    transition: color 200ms ease;
  }

  .ft-social svg {
    flex: 0 0 auto;
    opacity: 0.55;
  }

  .ft-social:active {
    color: rgba(255, 255, 255, 0.72);
  }

  @media (hover: hover) and (pointer: fine) {
    .ft-social:hover {
      color: rgba(255, 255, 255, 0.72);
    }
    .ft-social:hover svg {
      opacity: 0.9;
    }
  }

  /* ── Legal bottom ── */
  .ft-bottom {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .ft-engineering {
    display: flex;
    justify-content: flex-start;
    padding-bottom: 0.4rem;
  }

  .ft-legal {
    display: flex;
    flex-direction: column;
    gap: 0.28rem;
  }

  .ft-legal-name {
    font-size: 0.68rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.22);
    letter-spacing: 0.01em;
  }

  .ft-legal-detail,
  .ft-legal-copy {
    font-size: 0.64rem;
    font-family: monospace;
    letter-spacing: 0.04em;
    color: rgba(255, 255, 255, 0.14);
  }
</style>
