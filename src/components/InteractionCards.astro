---
import ProcessContent from "./ProcessContent.astro";
---

<section class="interaction-section">
  <div class="container">
    <div class="interaction-grid">
      <!-- CARD 1: ENTENDER A ARQUITETURA -->
      <button class="trigger-card" data-open-modal="modal-process">
        <div class="card-glow"></div>
        <div class="card-header">
          <span class="card-badge">DECISÃO 01</span>
          <span class="card-status">para entender</span>
        </div>
        <div class="card-body">
          <p class="section-label">Entender a arquitetura</p>
          <h2 class="card-title" aria-label="Ver como a estrutura opera">
            Ver como a <span class="text-pink">estrutura opera</span>
          </h2>
          <p class="card-summary">
            Abra a lógica por trás da captura, da leitura de contexto e da
            resposta comercial para entender onde a conversão realmente nasce.
          </p>
          <div class="card-footer">
            <span class="action-cmd">ABRIR VISÃO DA ARQUITETURA</span>
          </div>
        </div>
      </button>

      <!-- CARD 2: PEDIR DIAGNÓSTICO -->
      <button class="trigger-card" data-open-modal="modal-analysis">
        <div class="card-glow"></div>
        <div class="card-header">
          <span class="card-badge">DECISÃO 02</span>
          <span class="card-status">para agir</span>
        </div>
        <div class="card-body">
          <p class="section-label">Pedir diagnóstico</p>
          <h2 class="card-title" aria-label="Receber uma leitura inicial">
            Receber uma <span class="text-pink">leitura inicial</span>
          </h2>
          <p class="card-summary">
            Envie o contexto da sua operação e receba uma leitura objetiva dos
            gargalos mais prováveis entre tráfego, captura e continuidade.
          </p>
          <div class="card-footer">
            <span class="action-cmd">ABRIR DIAGNÓSTICO INICIAL</span>
          </div>
        </div>
      </button>
    </div>
  </div>

  <!-- MODAL: PROCESS -->
  <dialog id="modal-process" class="high-tech-modal">
    <div class="modal-backdrop"></div>
    <div class="modal-window">
      <div class="modal-handle"></div>
      <!-- iOS Sheet Handle -->
      <button class="modal-close" data-close-all aria-label="Fechar modal"
        >&times;</button
      >
      <div class="modal-header">
        <span class="modal-label">VISÃO DA ARQUITETURA</span>
        <h3>Entender como a estrutura opera</h3>
      </div>
      <div class="modal-scroll">
        <ProcessContent />
      </div>
    </div>
  </dialog>
</section>

<script is:inline>
  (function () {
    const processModal = document.getElementById("modal-process");

    const openModal = (modal) => {
      if (modal) {
        modal.showModal();
        document.documentElement.classList.add("modal-open");
      }
    };

    const closeModal = (modal) => {
      if (modal) {
        modal.close();
        document.documentElement.classList.remove("modal-open");
      }
    };

    // Card triggers
    document.querySelectorAll("[data-open-modal]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const targetId = btn.getAttribute("data-open-modal");
        if (targetId === "modal-process") {
          openModal(processModal);
        }
        // Analysis modal is handled globally by AnalysisModal.astro
      });
    });

    // Close buttons (specific to this component's modal if needed, but handled globally too)
    document.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-close-all]");
      if (btn && btn.closest("dialog") === processModal) {
        closeModal(processModal);
      }

      // Backdrop click
      if (e.target.tagName === "DIALOG" && e.target === processModal) {
        closeModal(processModal);
      }
    });
  })();
</script>

<style>
  .interaction-section {
    padding: 2rem 0;
    position: relative;
    z-index: 20;
  }

  .interaction-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  .trigger-card {
    position: relative;
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.05) 0%,
        rgba(255, 255, 255, 0.01) 100%
      ),
      rgba(9, 14, 24, 0.82);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 20px;
    padding: 2.5rem;
    text-align: left;
    cursor: pointer;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    backdrop-filter: blur(20px);
    display: block;
    width: 100%;
  }

  .trigger-card:hover {
    transform: translateY(-8px);
    border-color: rgba(255, 31, 143, 0.4);
    box-shadow:
      0 20px 40px rgba(0, 0, 0, 0.3),
      0 0 30px rgba(255, 31, 143, 0.1);
  }

  .card-glow {
    position: absolute;
    inset: 0;
    background: radial-gradient(
      circle at center,
      rgba(255, 31, 143, 0.1),
      transparent 70%
    );
    opacity: 0;
    transition: opacity 0.4s;
  }
  .trigger-card:hover .card-glow {
    opacity: 1;
  }

  .card-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .card-badge {
    font-size: 0.65rem;
    font-family: var(--font-mono, monospace);
    color: rgba(255, 255, 255, 0.68);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    letter-spacing: 0.1em;
  }

  .card-status {
    font-size: 0.6rem;
    font-weight: 800;
    color: rgba(255, 255, 255, 0.74);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .card-title {
    font-size: 2rem;
    font-weight: 900;
    line-height: 1.1;
    margin: 1rem 0;
    color: #fff;
    letter-spacing: -0.02em;
  }

  .card-summary {
    margin: 0;
    max-width: 34ch;
    color: var(--text-3);
    font-size: 0.98rem;
    line-height: 1.65;
  }

  .card-footer {
    margin-top: 2rem;
  }

  .action-cmd {
    font-family: var(--font-mono, monospace);
    font-size: 0.68rem;
    color: #ff1f8f;
    font-weight: 700;
    letter-spacing: 0.12em;
  }

  /* ── MODAL SYSTEM ── */
  .high-tech-modal {
    background: transparent;
    border: none;
    padding: 0;
    margin: auto;
    max-width: 800px;
    width: 90%;
    color: #fff;
    outline: none;
    overflow: visible;
    display: none; /* Force hidden by default */
  }

  .high-tech-modal[open] {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .high-tech-modal::backdrop {
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(12px);
    animation: fade-in 0.3s ease-out;
  }

  .modal-window {
    background: #090e18;
    border: 1px solid rgba(255, 31, 143, 0.15);
    border-radius: 32px;
    padding: 3rem;
    position: relative;
    box-shadow:
      0 30px 100px rgba(0, 0, 0, 0.8),
      0 0 50px rgba(255, 31, 143, 0.05);
    max-height: 85vh;
    display: flex;
    flex-direction: column;
    animation: modal-zoom 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .modal-handle {
    display: none;
    width: 40px;
    height: 5px;
    background: rgba(255, 255, 255, 0.2);
    border-radius: 999px;
    margin: 0.75rem auto 0;
    position: absolute;
    top: 5px;
    left: 50%;
    transform: translateX(-50%);
  }

  @keyframes modal-zoom {
    from {
      transform: scale(0.95) translateY(20px);
      opacity: 0;
    }
    to {
      transform: scale(1) translateY(0);
      opacity: 1;
    }
  }

  @keyframes fade-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  .modal-close {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #fff;
    width: 42px;
    height: 42px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.6rem;
    display: grid;
    place-items: center;
    transition: all 0.2s;
    z-index: 999; /* Boost z-index */
    pointer-events: auto;
  }

  /* ── iOS-Style Bottom Sheet (Mobile) ── */
  @media (max-width: 640px) {
    .high-tech-modal[open] {
      width: 100%;
      height: 100%;
      max-width: 100%;
      margin: 0;
      position: fixed;
      bottom: 0;
      display: flex;
      align-items: flex-end;
    }

    .modal-window {
      width: 100%;
      max-height: 92vh;
      border-radius: 32px 32px 0 0;
      padding: 3rem 1.5rem 2rem;
      border-bottom: none;
      animation: modal-sheet-up 0.5s cubic-bezier(0.32, 0.72, 0, 1);
    }

    .modal-handle {
      display: block;
    }

    @keyframes modal-sheet-up {
      from {
        transform: translateY(100%);
      }
      to {
        transform: translateY(0);
      }
    }

    .modal-close {
      top: 1rem;
      right: 1rem;
      width: 36px;
      height: 36px;
      font-size: 1.3rem;
    }
  }
  .modal-close:hover {
    background: #ff1f8f;
    border-color: #ff1f8f;
  }

  .modal-header {
    margin-bottom: 2rem;
  }

  .modal-label {
    font-size: 0.7rem;
    font-family: var(--font-mono, monospace);
    color: #ff1f8f;
    letter-spacing: 0.2em;
    display: block;
    margin-bottom: 0.5rem;
  }

  .modal-header h3 {
    font-size: 2rem;
    font-weight: 900;
    margin: 0;
  }

  .modal-body-meta {
    margin-bottom: 2rem;
    color: var(--text-3);
    font-size: 1.1rem;
    line-height: 1.5;
  }

  .modal-scroll {
    overflow-y: auto;
    padding-right: 10px;
  }

  /* Custom Scrollbar */
  .modal-scroll::-webkit-scrollbar {
    width: 4px;
  }
  .modal-scroll::-webkit-scrollbar-track {
    background: transparent;
  }
  .modal-scroll::-webkit-scrollbar-thumb {
    background: rgba(255, 31, 143, 0.3);
    border-radius: 10px;
  }

  @media (max-width: 980px) {
    .interaction-grid {
      gap: 1rem;
    }
    .trigger-card {
      padding: 1.5rem;
    }
    .card-title {
      font-size: 1.25rem;
    }
    .modal-window {
      padding: 2rem;
    }
  }

  @media (max-width: 500px) {
    .trigger-card {
      padding: 1.1rem;
    }
    .card-title {
      font-size: 1.1rem;
    }
    .card-header {
      margin-bottom: 1.25rem;
    }
    .card-badge {
      font-size: 0.55rem;
      padding: 0.15rem 0.35rem;
    }
    .action-cmd {
      font-size: 0.65rem;
    }
    .card-footer {
      margin-top: 1.25rem;
    }
  }
</style>
