---
const steps = [
  {
    n: "01",
    title: "Diagnóstico",
    text: "Analisamos site, proposta, jornada, gargalos e pontos de perda.",
  },
  {
    n: "02",
    title: "Estrutura",
    text: "Definimos páginas, fluxos, eventos, formulários, CTAs e leitura de dados.",
  },
  {
    n: "03",
    title: "Construção",
    text: "Desenvolvemos landing page, site, webapp ou dashboard conforme a necessidade real.",
  },
  {
    n: "04",
    title: "Operação",
    text: "Conectamos automações e organizamos o digital para apoiar o comercial de forma contínua.",
  },
];
---

<div class="process-content-wrapper">
  <div class="proc-title">
    <h2>Arquitetura antes de estética. Conversão antes de volume.</h2>
  </div>

  <div class="proc-track" aria-label="Roadmap de trabalho">
    <!-- line + traveling orb -->
    <div class="proc-line" aria-hidden="true">
      <div class="proc-orb"></div>
    </div>

    {
      steps.map((step, i) => (
        <div class="proc-step" style={`--i:${i}`}>
          <div class="proc-node" aria-hidden="true">
            <span class="proc-num">{step.n}</span>
          </div>
          <div class="proc-content">
            <strong class="proc-step-title">{step.title}</strong>
            <p class="proc-step-text">{step.text}</p>
          </div>
        </div>
      ))
    }
  </div>
</div>

<style>
  .proc-title {
    padding: 0 0 2rem;
    border-bottom: 1px solid rgba(255, 31, 143, 0.1);
    margin-bottom: 2rem;
  }

  .proc-title h2 {
    font-size: 1.8rem;
    font-weight: 800;
    margin: 0;
    color: #fff;
    line-height: 1.2;
  }

  /* ── Track ── */
  .proc-track {
    position: relative;
    padding-left: 50px;
  }

  /* vertical pipeline */
  .proc-line {
    position: absolute;
    left: 17px;
    top: 18px;
    bottom: 18px;
    width: 2px;
    background: rgba(255, 31, 143, 0.1);
    border-radius: 999px;
    overflow: hidden;
  }

  /* traveling orb */
  .proc-orb {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 52px;
    border-radius: 999px;
    background: linear-gradient(
      180deg,
      transparent 0%,
      #ff1f8f 50%,
      transparent 100%
    );
    box-shadow: 0 0 12px 2px rgba(255, 31, 143, 0.55);
    animation: orb-travel 4s linear infinite;
  }

  @keyframes orb-travel {
    0% {
      top: -20px;
      opacity: 1;
    }
    100% {
      top: 100%;
      opacity: 1;
    }
  }

  /* ── Steps ── */
  .proc-step {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
    padding: 1.2rem 0;
  }

  .proc-node {
    position: absolute;
    left: 0;
    z-index: 2;
    display: grid;
    place-items: center;
    width: 36px;
    height: 36px;
    border-radius: 999px;
    background: rgba(255, 31, 143, 0.07);
    border: 1px solid rgba(255, 31, 143, 0.15);
    animation: node-activate 4s linear calc(var(--i) * -1s) infinite;
  }

  @keyframes node-activate {
    0% {
      background: rgba(255, 31, 143, 0.42);
      border-color: rgba(255, 31, 143, 0.85);
      box-shadow:
        0 0 20px rgba(255, 31, 143, 0.55),
        inset 0 0 8px rgba(255, 31, 143, 0.2);
    }
    12% {
      background: rgba(255, 31, 143, 0.18);
      border-color: rgba(255, 31, 143, 0.38);
      box-shadow: 0 0 10px rgba(255, 31, 143, 0.22);
    }
    25%,
    100% {
      background: rgba(255, 31, 143, 0.06);
      border-color: rgba(255, 31, 143, 0.12);
      box-shadow: none;
    }
  }

  .proc-num {
    font-size: 0.7rem;
    font-weight: 800;
    font-family: monospace;
    color: #ff7ac4;
    animation: num-activate 4s linear calc(var(--i) * -1s) infinite;
  }

  @keyframes num-activate {
    0% {
      color: #ffb3de;
    }
    12% {
      color: #ff60b5;
    }
    25%,
    100% {
      color: #ff7ac4;
    }
  }

  .proc-step-title {
    display: block;
    margin-bottom: 0.4rem;
    font-size: 1.1rem;
    font-weight: 800;
    color: #fff;
    animation: title-activate 4s linear calc(var(--i) * -1s) infinite;
  }

  @keyframes title-activate {
    0% {
      color: #ff1f8f;
    }
    12% {
      color: #fff;
    }
  }

  .proc-step-text {
    margin: 0;
    font-size: 0.95rem;
    color: var(--text-3);
    line-height: 1.6;
  }
</style>
