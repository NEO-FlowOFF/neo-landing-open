---
const items = [
  {
    severity: "CRÍTICO",
    impact: 92,
    text: "Captura de dados sem inteligência",
    accent: "#ff1f8f",
  },
  {
    severity: "CRÍTICO",
    impact: 88,
    text: "Fluxo comercial desorganizado",
    accent: "#ff1f8f",
  },
  {
    severity: "ALERTA",
    impact: 74,
    text: "Confusão entre curiosidade e intenção",
    accent: "#d9ff3f",
  },
  {
    severity: "CRÍTICO",
    impact: 85,
    text: "Isolamento de automações e dashboards",
    accent: "#ff1f8f",
  },
  {
    severity: "ALERTA",
    impact: 71,
    text: "Baixa conversão de visita em processo",
    accent: "#d9ff3f",
  },
];
---

<section id="diagnostico" class="section diag-section">
  <div class="container">
    <div class="diag-header-outer">
      <p class="section-label">Diagnóstico do seu sistema</p>
      <h2
        class="tech-title"
        aria-label="A arquitetura atual do seu sistema atrapalha a eficiência operacional e o crescimento."
      >
        A arquitetura atual do seu sistema <span class="technical-tag"
          >atrapalha</span
        >
        a eficiência operacional e o crescimento.
      </h2>
    </div>

    <div class="diagnostic-terminal" id="diag-terminal">
      <!-- HUD DECORATIONS -->
      <div class="hud-corner top-left"></div>
      <div class="hud-corner top-right"></div>
      <div class="hud-corner bottom-left"></div>
      <div class="hud-corner bottom-right"></div>

      <div class="terminal-header">
        <div class="terminal-status">
          <span class="status-pulse"></span>
          <span class="status-text">NΞØ PROTOCOLO // ATIVO</span>
        </div>
        <div class="terminal-meta">
          <span class="meta-item">VERSÃO: <b class="cyan-txt">V3.8</b></span>
          <span class="meta-item"
            >LOC: <b class="cyan-txt" id="user-loc">GYN, BRASIL</b></span
          >
        </div>
        <div class="terminal-tag">AUDIT_STREAK: 99.8%</div>
      </div>

      <div class="terminal-log">
        <div class="log-scroll">
          SCANEANDO SEU SISTEMA... TRACKEANDO CONVERSAS PERDIDAS...
          INICIANDO_NΞØ_PROTOCOL_08... UPLOADING_PERFORMANCE_METRICS...
          CORE_TEMP_STABLE... NODE_ACTIVE_01... BUSCANDO VULNERABILIDADES...
        </div>
      </div>

      <div
        class="proof-panel"
        aria-label="Prova viva de contexto em tempo real"
      >
        <div class="proof-head">
          <span class="proof-kicker">PROVA VIVA</span>
          <p class="proof-copy">
            Esta interface não simula contexto. Ela lê a borda, interpreta o
            sinal e mantém fallback operacional.
          </p>
        </div>

        <div class="proof-grid">
          <div class="proof-card">
            <span class="proof-label">CONTEXTO DETECTADO</span>
            <strong class="proof-value" id="ctx-location">GYN, BRASIL</strong>
          </div>
          <div class="proof-card">
            <span class="proof-label">ORIGEM DO SINAL</span>
            <strong class="proof-value" id="ctx-source">EDGE</strong>
          </div>
          <div class="proof-card">
            <span class="proof-label">LATÊNCIA PERCEBIDA</span>
            <strong class="proof-value" id="ctx-latency">-- ms</strong>
          </div>
          <div class="proof-card">
            <span class="proof-label">MODO DE ENTREGA</span>
            <strong class="proof-value" id="ctx-mode">SAME ORIGIN</strong>
          </div>
          <div class="proof-card">
            <span class="proof-label">HORA LOCAL</span>
            <strong class="proof-value" id="ctx-time">--:--</strong>
          </div>
          <div class="proof-card">
            <span class="proof-label">IDIOMA DA SESSÃO</span>
            <strong class="proof-value" id="ctx-language">PT-BR</strong>
          </div>
          <div class="proof-card">
            <span class="proof-label">ENTRADA DA SESSÃO</span>
            <strong class="proof-value" id="ctx-entry">ACESSO DIRETO</strong>
          </div>
        </div>
      </div>

      <div class="diag-items-wrap" id="diag-list">
        <div class="diag-scanner-line"></div>

        {
          items.map((item, i) => (
            <div
              class="diag-item-box"
              style={`--i:${i}; --accent:${item.accent}`}
              data-impact={item.impact}
            >
              <div class="diag-item-inner">
                <div class="item-head">
                  <div class="item-id">
                    <span class={`level-badge ${item.severity.toLowerCase()}`}>
                      {item.severity}
                    </span>
                    <span class="ref-code">REF.{1024 + i * 11}</span>
                  </div>
                  <div class="item-stats">
                    <>
                      <span class="impact-num">0</span>
                      <span class="impact-pct">%</span>
                    </>
                    <span class="impact-lbl"> GAP DE DESTRUIÇÃO DE VALOR</span>
                  </div>
                </div>

                <h3 class="item-title">{item.text}</h3>

                <div class="bar-system">
                  <div class="bar-rail">
                    <div class="bar-fill">
                      <div class="bar-glow" />
                      <div class="bar-head" />
                    </div>
                  </div>
                  <div class="bar-meta">
                    ANALYSING_DATA_FLOW... STATUS: CRITICAL
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <div class="terminal-footer">
        <div class="alert-msg">
          <span class="alert-icon">!</span>
          5 FALHAS ESTRUTURAIS DETECTADAS NO SEU ECOSSISTEMA ATUAL
        </div>
        <div class="terminal-stats">
          SCAN: 99.99% | BOOT: 12ms | NODE: ALPHA-4
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const list = document.getElementById("diag-list");
    if (!list) return;

    const items = list.querySelectorAll(".diag-item-box");
    let ran = false;

    function animate() {
      if (ran) return;
      ran = true;

      items.forEach((item, idx) => {
        setTimeout(() => {
          item.classList.add("is-active");

          const target = parseInt(item.dataset.impact, 10);
          const fill = item.querySelector(".bar-fill");
          const num = item.querySelector(".impact-num");

          if (fill) fill.style.width = target + "%";
          if (!num) return;

          const duration = 1500;
          let startTime = null;

          function step(ts) {
            if (!startTime) startTime = ts;
            const p = Math.min((ts - startTime) / duration, 1);
            const ease = 1 - Math.pow(1 - p, 3); // Cubic ease out
            num.textContent = Math.round(ease * target);
            if (p < 1) requestAnimationFrame(step);
          }
          requestAnimationFrame(step);
        }, idx * 200);
      });
    }

    var observer = new IntersectionObserver(
      (entries) => {
        if (entries[0].isIntersecting) {
          setTimeout(animate, 500);
          observer.disconnect();
        }
      },
      { threshold: 0.15 },
    );
    // Dynamic Geolocation via IP (Silent)
    const locEl = document.getElementById("user-loc");
    const ctxLocationEl = document.getElementById("ctx-location");
    const ctxSourceEl = document.getElementById("ctx-source");
    const ctxLatencyEl = document.getElementById("ctx-latency");
    const ctxModeEl = document.getElementById("ctx-mode");
    const ctxTimeEl = document.getElementById("ctx-time");
    const ctxLanguageEl = document.getElementById("ctx-language");
    const ctxEntryEl = document.getElementById("ctx-entry");
    let clockTimer;

    function toLabel(source) {
      const sourceMap = {
        "edge.cloudflare": "EDGE CLOUDFLARE",
        "edge.vercel": "EDGE VERCEL",
        "edge.partial": "EDGE PARCIAL",
        "fallback.freeipapi": "FALLBACK FREEIPAPI",
        "fallback.local": "FAILSAFE LOCAL",
      };

      return sourceMap[source] || "SINAL INDEFINIDO";
    }

    function toLanguageLabel(code) {
      if (!code) return "PT-BR";
      return code.replace("_", "-").toUpperCase();
    }

    function detectEntry() {
      const params = new URLSearchParams(window.location.search);
      const utmSource = params.get("utm_source");
      if (utmSource) return `UTM ${utmSource}`.toUpperCase();

      if (!document.referrer) return "ACESSO DIRETO";

      try {
        const host = new URL(document.referrer).hostname.replace(/^www\./, "");
        return host.toUpperCase();
      } catch {
        return "REFERÊNCIA EXTERNA";
      }
    }

    function startClock(timeZone) {
      if (!ctxTimeEl) return;
      if (clockTimer) clearInterval(clockTimer);

      const render = () => {
        try {
          const formatter = new Intl.DateTimeFormat("pt-BR", {
            hour: "2-digit",
            minute: "2-digit",
            timeZone:
              timeZone || Intl.DateTimeFormat().resolvedOptions().timeZone,
          });
          ctxTimeEl.innerText = formatter.format(new Date());
        } catch {
          ctxTimeEl.innerText = "--:--";
        }
      };

      render();
      clockTimer = setInterval(render, 30000);
    }

    if (locEl) {
      locEl.innerText = "LOCALIZANDO...";
      if (ctxLocationEl) ctxLocationEl.innerText = "LOCALIZANDO...";
      if (ctxEntryEl) ctxEntryEl.innerText = detectEntry();
      const controller = new AbortController();
      const timeoutId = setTimeout(() => controller.abort(), 4000);
      const start = performance.now();

      fetch("/api/geo", {
        signal: controller.signal,
      })
        .then((res) => {
          if (!res.ok) throw new Error(`IP lookup failed: ${res.status}`);
          return res.json();
        })
        .then((data) => {
          clearTimeout(timeoutId);
          const latency = Math.max(1, Math.round(performance.now() - start));
          if (ctxLatencyEl) ctxLatencyEl.innerText = `${latency} ms`;
          if (ctxSourceEl) ctxSourceEl.innerText = toLabel(data?.source);
          if (ctxModeEl) {
            ctxModeEl.innerText = data?.mode
              ? data.mode.toUpperCase().replace("-", " ")
              : "SAME ORIGIN";
          }
          if (ctxLanguageEl) {
            ctxLanguageEl.innerText = toLanguageLabel(
              data?.language || navigator.language,
            );
          }
          startClock(data?.timezone);

          if (data && data.city && data.country) {
            const location = `${data.city.toUpperCase()}, ${data.country.toUpperCase()}`;
            locEl.innerText = location;
            if (ctxLocationEl) ctxLocationEl.innerText = location;
          } else {
            locEl.innerText = "GYN, BRASIL"; // Fallback
            if (ctxLocationEl) ctxLocationEl.innerText = "GYN, BRASIL";
          }
        })
        .catch(() => {
          clearTimeout(timeoutId);
          const latency = Math.max(1, Math.round(performance.now() - start));
          locEl.innerText = "GYN, BRASIL"; // Fallback on block/error
          if (ctxLocationEl) ctxLocationEl.innerText = "GYN, BRASIL";
          if (ctxSourceEl) ctxSourceEl.innerText = "FAILSAFE LOCAL";
          if (ctxLatencyEl) ctxLatencyEl.innerText = `${latency} ms`;
          if (ctxModeEl) ctxModeEl.innerText = "SAME ORIGIN";
          if (ctxLanguageEl) {
            ctxLanguageEl.innerText = toLanguageLabel(navigator.language);
          }
          startClock();
        });
    }

    observer.observe(list);
  })();
</script>

<style>
  .diag-section {
    padding: 10rem 0;
    background: radial-gradient(
      circle at 50% -10%,
      rgba(51, 214, 255, 0.05),
      transparent 40%
    );
  }

  .tech-title {
    margin-top: 0.5rem;
    font-weight: 900;
  }

  .glitch-txt {
    color: var(--pink);
    text-shadow: 2px 0 #33d6ff;
  }

  .diagnostic-terminal {
    position: relative;
    background: rgba(6, 9, 15, 0.98);
    border: 1px solid rgba(51, 214, 255, 0.2);
    border-radius: 16px;
    padding: 2.5rem;
    box-shadow:
      0 0 100px rgba(0, 0, 0, 0.8),
      inset 0 0 40px rgba(51, 214, 255, 0.03);
    overflow: hidden;
  }

  /* HUD */
  .hud-corner {
    position: absolute;
    width: 32px;
    height: 32px;
    border: 2px solid rgba(51, 214, 255, 0.4);
    pointer-events: none;
  }
  .top-left {
    top: 12px;
    left: 12px;
    border-right: 0;
    border-bottom: 0;
  }
  .top-right {
    top: 12px;
    right: 12px;
    border-left: 0;
    border-bottom: 0;
  }
  .bottom-left {
    bottom: 12px;
    left: 12px;
    border-right: 0;
    border-top: 0;
  }
  .bottom-right {
    bottom: 12px;
    right: 12px;
    border-left: 0;
    border-top: 0;
  }

  .terminal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(51, 214, 255, 0.15);
    padding-bottom: 1.5rem;
    margin-bottom: 1.5rem;
    font-family: var(--font-mono, monospace);
  }

  .terminal-status {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .status-pulse {
    width: 8px;
    height: 8px;
    background: #33d6ff;
    border-radius: 50%;
    box-shadow: 0 0 15px #33d6ff;
    animation: diag-pulse 2s infinite;
  }

  .status-text {
    font-size: 0.75rem;
    font-weight: 900;
    color: #33d6ff;
    letter-spacing: 0.15em;
  }

  .terminal-meta {
    display: flex;
    gap: 1.5rem;
    font-size: 0.65rem;
    color: var(--text-4);
  }

  .cyan-txt {
    color: #33d6ff;
    font-weight: 700;
  }
  .terminal-tag {
    font-size: 0.65rem;
    color: var(--text-4);
  }

  .terminal-log {
    background: rgba(0, 0, 0, 0.4);
    border: 1px solid rgba(51, 214, 255, 0.1);
    padding: 0.6rem 0;
    margin-bottom: 1.35rem;
    overflow: hidden;
  }

  .log-scroll {
    white-space: nowrap;
    font-family: var(--font-mono, monospace);
    font-size: 0.6rem;
    color: rgba(51, 214, 255, 0.62);
    letter-spacing: 0.2em;
    animation: log-scroll 40s linear infinite;
  }

  .diag-items-wrap {
    display: grid;
    gap: 1.25rem;
    position: relative;
    z-index: 2;
  }

  .proof-panel {
    margin-bottom: 2rem;
    padding: 1.2rem;
    border: 1px solid rgba(51, 214, 255, 0.14);
    background:
      linear-gradient(135deg, rgba(51, 214, 255, 0.07), transparent 58%),
      rgba(255, 255, 255, 0.025);
    border-radius: 14px;
  }

  .proof-head {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .proof-kicker {
    flex: 0 0 auto;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    border: 1px solid rgba(217, 255, 63, 0.3);
    color: var(--acid);
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    font-family: var(--font-mono, monospace);
  }

  .proof-copy {
    margin: 0;
    max-width: 56ch;
    color: var(--text-3);
    font-size: 0.88rem;
    line-height: 1.55;
  }

  .proof-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .proof-card {
    min-width: 0;
    padding: 1rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    background: rgba(4, 8, 14, 0.72);
  }

  .proof-label {
    display: block;
    margin-bottom: 0.55rem;
    color: var(--text-4);
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    font-family: var(--font-mono, monospace);
  }

  .proof-value {
    display: block;
    color: #f4fbff;
    font-size: 1rem;
    line-height: 1.25;
    letter-spacing: 0.03em;
    font-family: var(--font-mono, monospace);
  }

  .diag-item-box {
    opacity: 0;
    transform: translateY(20px);
    transition: all 800ms cubic-bezier(0.16, 1, 0.3, 1);
  }

  .diag-item-box.is-active {
    opacity: 1;
    transform: translateY(0);
  }

  .diag-item-inner {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 12px;
    padding: 1.5rem 1.8rem;
    position: relative;
    overflow: hidden;
  }

  .item-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1.2rem;
  }

  .item-id {
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .level-badge {
    padding: 0.3rem 0.6rem;
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    border-radius: 4px;
    text-transform: uppercase;
  }
  .level-badge.crítico {
    background: var(--pink);
    color: #fff;
    box-shadow: 0 0 20px rgba(255, 31, 143, 0.4);
  }
  .level-badge.alerta {
    background: #d9ff3f;
    color: #000;
    box-shadow: 0 0 20px rgba(217, 255, 63, 0.4);
  }

  .ref-code {
    font-family: var(--font-mono, monospace);
    font-size: 0.7rem;
    color: var(--text-4);
  }

  .item-stats {
    text-align: right;
  }
  .impact-num {
    font-size: 1.8rem;
    font-weight: 900;
    color: #fff;
    font-family: var(--font-mono, monospace);
  }
  .impact-pct {
    font-size: 1rem;
    color: var(--text-3);
    font-weight: 700;
  }
  .impact-lbl {
    display: block;
    font-size: 0.6rem;
    color: var(--text-4);
    font-weight: 800;
    letter-spacing: 0.05em;
  }

  .item-title {
    font-size: 1.35rem;
    margin-bottom: 1.8rem;
    color: #fff;
    letter-spacing: -0.01em;
  }

  .tech-title {
    font-size: 3rem;
    font-weight: 800;
    margin-bottom: 3rem;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: #fff;
  }

  /* High-Tech Highlight Classes */
  .technical-tag {
    font-family: var(--font-mono, monospace);
    font-size: 0.9em;
    background: rgba(255, 31, 143, 0.1);
    border: 1px dashed rgba(255, 31, 143, 0.4);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    color: var(--pink);
    text-transform: uppercase;
    display: inline-block;
    vertical-align: middle;
    margin: 0 0.2rem;
  }

  .scan-highlight {
    position: relative;
    overflow: hidden;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.4),
      transparent
    );
    background-size: 200% 100%;
    background-clip: text;
    -webkit-background-clip: text;
    animation: text-scan-line 3s linear infinite;
  }

  .glow-pink {
    text-shadow:
      0 0 10px rgba(255, 31, 143, 0.5),
      0 0 20px rgba(255, 31, 143, 0.3);
  }

  @keyframes text-scan-line {
    0% {
      background-position: -100% 0;
    }
    100% {
      background-position: 100% 0;
    }
  }

  .bar-system {
    margin-bottom: 0.5rem;
  }
  .bar-rail {
    height: 8px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 4px;
    overflow: hidden;
    position: relative;
  }
  .bar-fill {
    height: 100%;
    width: 0%;
    background: var(--accent);
    border-radius: 4px;
    position: relative;
    transition: width 2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .bar-glow {
    position: absolute;
    inset: 0;
    background: inherit;
    filter: blur(12px);
    opacity: 0.8;
  }

  .bar-head {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    width: 20px;
    background: linear-gradient(90deg, transparent, #fff);
    opacity: 0.5;
  }

  .bar-meta {
    font-family: var(--font-mono, monospace);
    font-size: 0.55rem;
    color: var(--text-4);
    margin-top: 0.8rem;
    letter-spacing: 0.1em;
  }

  .diag-scanner-line {
    position: absolute;
    top: -100px;
    left: 0;
    width: 100%;
    height: 120px;
    background: linear-gradient(
      180deg,
      transparent,
      rgba(51, 214, 255, 0.15),
      transparent
    );
    border-bottom: 2px solid rgba(51, 214, 255, 0.6);
    box-shadow: 0 10px 40px rgba(51, 214, 255, 0.2);
    z-index: 5;
    pointer-events: none;
    animation: diag-scan 5s linear infinite;
  }

  .terminal-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgba(51, 214, 255, 0.15);
    font-family: var(--font-mono, monospace);
  }

  .alert-msg {
    color: var(--pink);
    font-size: 0.75rem;
    font-weight: 900;
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .alert-icon {
    display: grid;
    place-items: center;
    width: 18px;
    height: 18px;
    background: var(--pink);
    color: #fff;
    border-radius: 50%;
    font-size: 0.7rem;
  }
  .terminal-stats {
    font-size: 0.65rem;
    color: var(--text-4);
  }

  @keyframes log-scroll {
    from {
      transform: translateX(100%);
    }
    to {
      transform: translateX(-100%);
    }
  }
  @keyframes diag-scan {
    0% {
      top: -120px;
    }
    100% {
      top: 100%;
    }
  }
  @keyframes diag-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.3);
      opacity: 0.5;
    }
  }

  @media (max-width: 980px) {
    .terminal-header {
      flex-direction: column;
      gap: 1rem;
      align-items: flex-start;
    }
    .proof-head {
      flex-direction: column;
    }
    .proof-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .terminal-footer {
      flex-direction: column;
      gap: 1.25rem;
      align-items: flex-start;
    }
  }

  @media (max-width: 640px) {
    .diagnostic-terminal {
      padding: 1.5rem;
    }
    .proof-grid {
      grid-template-columns: 1fr;
    }
    .item-stats {
      display: none;
