---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import heroLogo from "../assets/neoflowoff_logo.png";
import imgFitness from "../assets/provas/fitness.png";
import imgPunk from "../assets/provas/punk-blvck.png";
import imgFlowpay from "../assets/provas/flowpay.png";
import imgFactory from "../assets/provas/nsfactory.png";

type ImgSlide = { type: "img"; src: ImageMetadata; alt: string };
type TextSlide = { type: "text"; tag: string; body: string };
type Slide = ImgSlide | TextSlide;

const slides: Slide[] = [
  { type: "img", src: imgFitness, alt: "Fitness webapp" },
      {
    type: "text",
    tag: "Landing Page",
    body: `Uma landing page <em>comum</em> informa.<br/>Uma estratégica condiciona <strong>percepção.</strong><br/><br/>Ela:<br/> ‣ Reduz fricção cognitiva<br/> ‣ Antecipa objeções antes de surgirem<br/> ‣ Direciona microdecisões invisíveis<br/> ‣ Cria sensação de inevitabilidade na ação<br/><br/>O usuário não “decide comprar”.<br/>Ele apenas segue um caminho que já foi desenhado.`,
  },
  { type: "img", src: imgPunk, alt: "Punk BLVCK webapp" },
  {
    type: "text",
    tag: "WebApp",
    body: `Um WebApp <em>bem estruturado</em> não exibe informação.<br/>Ele condiciona <strong>comportamento operacional.</strong><br/><br/>Ele:<br/> ‣ Organiza dados em decisões acionáveis<br/> ‣ Reduz ambiguidade na operação<br/> ‣ Elimina dependência de interpretação humana<br/> ‣ Conecta eventos em tempo real com respostas imediatas<br/><br/>Você não analisa o negócio.<br/>O sistema responde por ele.`,
  },
  { type: "img", src: imgFlowpay, alt: "Flowpay dashboard" },
  {
    type: "text",
    tag: "Captação",
    body: `Captação conectada à <strong>gestão inteligente de dados</strong><br/><br/>Com:<br/> ‣ Landing pages que coletam dados relevantes<br/> ‣ Estruturação automática no CRM<br/> ‣ Classificação por comportamento e origem<br/> ‣ Organização em pipelines reais<br/> ‣ Atualização contínua de status<br/> ‣ Integração com automações e WebApps<br/><br/>Cada lead entra identificado.<br/><strong>Não como número.</strong>`,
  },
  { type: "img", src: imgFactory, alt: "NS Factory webapp" },
  {
    type: "text",
    tag: "Automação",
    body: `Automações conectadas ao seu <strong>funil real</strong>, não isoladas<br/><br/>Com:<br/> ‣ Resposta automática em segundos<br/> ‣ Distribuição inteligente de leads<br/> ‣ Sequências de follow-up por comportamento<br/> ‣ Atualização automática de status no pipeline<br/> ‣ Integração com pagamentos e conversão<br/> ‣ Gatilhos por evento, não por agenda<br/><br/>Cada lead entra em um sistema.<br/><strong>Não em uma fila.</strong>`,
  },
];
---

<section class="section hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <Image
        class="hero-logo-sm"
        src={heroLogo}
        alt="NEØ FlowOFF"
        width={88}
        height={88}
        loading="eager"
        fetchpriority="high"
        widths={[120, 200]}
        sizes="96px"
      />

      <div class="hero-hud">
        <span class="hud-item"><span class="hud-dot"></span> STATUS: OPERACIONAL</span>
        <span class="hud-item">LATENCY: 0.02ms</span>
        <span class="hud-item">COORD: 23°S 46°W</span>
      </div>

      <div class="eyebrow"><span class="tech-bracket">[</span> EXPERIMENTE UM WEBAPP <span class="tech-bracket">]</span></div>

      <h1>
        A maioria dos sites
        <span class="pink-script">informa.</span><br/>
        Poucos
        <span class="acid">operam vendas.</span>
      </h1>

      <p class="hero-lead">
        Sua empresa não precisa de mais uma vitrine digital. Precisa de uma
        estrutura que capture demanda, organize dados e converta intenção em lucro real.
      </p>

      <div class="hero-actions">
        <div class="cta-acid-shell">
          <div class="cta-acid-label" aria-hidden="true">
            <span class="cta-acid-dot"></span>
            análise gratuita
          </div>
          <a href="#form" class="btn btn-primary hero-btn-primary btn-glow">
            Solicitar análise
            <svg
              class="hero-btn-icon"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
        <a href="#solution" class="btn btn-secondary hero-btn-secondary">
          <svg
            class="hero-btn-icon-left"
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle><path d="M12 8v4l3 3"
            ></path>
          </svg>
          Ver como funciona
        </a>
      </div>

      <!-- gondola carousel -->
      <div class="gondola-wrap">
        <div class="gondola-shell">
          <ul class="gondola" id="gondola" aria-label="Serviços em destaque">
            {
              slides.map((slide, i) => (
                <li class="gondola-card" data-index={i}>
                  {slide.type === "img" ? (
                    <Image
                      class="gondola-img"
                      src={slide.src}
                      alt={slide.alt}
                      widths={[320, 480]}
                      sizes="280px"
                      loading={i < 2 ? "eager" : "lazy"}
                    />
                  ) : (
                    <div class="gondola-text-card">
                      <div class="gondola-badge-shell">
                        <span class="gondola-tag">{slide.tag}</span>
                        <div class="gondola-badge-line"></div>
                      </div>
                      <p class="gondola-body" set:html={slide.body} />
                      <div class="gondola-footer-acc">
                        <svg
                          class="gondola-arrow"
                          width="14"
                          height="14"
                          viewBox="0 0 24 24"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2.5"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          aria-hidden="true"
                        >
                          <path d="M7 17L17 7M17 7H7M17 7v10" />
                        </svg>
                      </div>
                    </div>
                  )}
                </li>
              ))
            }
          </ul>
        </div>

        <div class="gondola-dots" aria-hidden="true">
          {slides.map((_, i) => <span class="gondola-dot" data-dot={i} />)}
        </div>
      </div>
    </div>
  </div>
</section>

<script is:inline>
  (function () {
    const track = document.getElementById("gondola");
    const dots = document.querySelectorAll("[data-dot]");
    if (!track) return;

    const cards = track.querySelectorAll(".gondola-card");
    const total = cards.length;
    let current = 0;
    let cachedCardWidth = 0;
    let isTicking = false;

    const cacheWidth = () => {
      cachedCardWidth = cards[0] ? cards[0].offsetWidth + 12 : 292;
    };

    const goTo = (idx) => {
      current = (idx + total) % total;
      track.scrollTo({ left: current * cachedCardWidth, behavior: "smooth" });
      dots.forEach((d, i) => {
        d.classList.toggle("is-active", i === current);
      });
    };

    const peek = () => {
      setTimeout(() => {
        track.scrollTo({ left: 50, behavior: "smooth" });
        setTimeout(() => {
          track.scrollTo({ left: 0, behavior: "smooth" });
        }, 500);
      }, 1000);
    };

    const updateSync = () => {
      if (!track) {
        isTicking = false;
        return;
      }
      const idx = Math.round(track.scrollLeft / cachedCardWidth);
      current = (idx + total) % total;
      dots.forEach((d, i) => {
        d.classList.toggle("is-active", i === current);
      });
      isTicking = false;
    };

    const syncOnScroll = () => {
      if (!isTicking) {
        requestAnimationFrame(updateSync);
        isTicking = true;
      }
    };

    track.addEventListener("scroll", syncOnScroll, { passive: true });

    cacheWidth();
    goTo(0);
    peek();

    window.addEventListener(
      "resize",
      () => {
        cacheWidth();
      },
      { passive: true },
    );

    document.addEventListener("astro:after-swap", () => {
      cacheWidth();
      goTo(0);
    });
  })();
</script>

<style>
  /* ── Logo small ── */
  /*
    The source PNG (1024×1024) has ~20% transparent padding on every side.
    At 88px rendered width that's ≈18px of dead space top/bottom.
    Negative margins pull adjacent content back in so the actual glyph
    feels flush — no crop, no background hack needed.
  */
  .hero-hud {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
    font-family: var(--font-mono, monospace);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-4);
    letter-spacing: 0.1em;
  }

  .hud-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hud-dot {
    width: 6px;
    height: 6px;
    background: #33d6ff;
    border-radius: 50%;
    box-shadow: 0 0 10px #33d6ff;
    animation: diag-pulse 2s infinite;
  }

  .tech-bracket {
    color: #33d6ff;
    opacity: 0.6;
    font-weight: 400;
  }

  .hero-logo-sm {
    display: block;
    width: 88px;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
    filter: drop-shadow(0 0 14px rgba(255, 31, 143, 0.22))
      drop-shadow(0 0 24px rgba(51, 214, 255, 0.14));
  }

  /* ── CTA acid container ── */
  .cta-acid-shell {
    position: relative;
    border-radius: 999px;
    padding: 3px;
    background: linear-gradient(
      135deg,
      rgba(217, 255, 63, 0.55) 0%,
      rgba(217, 255, 63, 0.15) 50%,
      rgba(51, 214, 255, 0.18) 100%
    );
    box-shadow:
      0 0 24px rgba(217, 255, 63, 0.18),
      0 0 48px rgba(217, 255, 63, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  /* inner dark fill so the gradient acts as border */
  .cta-acid-shell::before {
    content: "";
    position: absolute;
    inset: 3px;
    border-radius: 999px;
    background: rgba(6, 10, 18, 0.92);
    backdrop-filter: blur(12px);
    z-index: 0;
  }

  .cta-acid-label {
    position: absolute;
    top: -9px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.14rem 0.55rem;
    border-radius: 999px;
    background: rgba(217, 255, 63, 0.12);
    border: 1px solid rgba(217, 255, 63, 0.32);
    backdrop-filter: blur(8px);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(217, 255, 63, 0.85);
    white-space: nowrap;
  }

  .cta-acid-dot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #d9ff3f;
    box-shadow: 0 0 6px rgba(217, 255, 63, 0.9);
    animation: acid-dot-pulse 1.8s ease-in-out infinite;
  }

  @keyframes acid-dot-pulse {
    0%,
    100% {
      opacity: 1;
      box-shadow: 0 0 6px rgba(217, 255, 63, 0.9);
    }
    50% {
      opacity: 0.3;
      box-shadow: none;
    }
  }

  /* button sits above the ::before overlay */
  .cta-acid-shell .btn {
    position: relative;
    z-index: 1;
  }

  /* ── Gondola wrapper ── */
  .gondola-wrap {
    margin-top: 1.35rem;
    margin-bottom: 0.75rem;
  }

  .gondola-shell {
    border-radius: var(--radius);
    border: 1px solid rgba(51, 214, 255, 0.1);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.04),
        rgba(255, 255, 255, 0.01)
      ),
      rgba(6, 10, 18, 0.85);
    backdrop-filter: blur(20px) saturate(1.15);
    box-shadow:
      0 12px 32px rgba(0, 0, 0, 0.24),
      inset 0 0 0 1px rgba(255, 255, 255, 0.02);
    overflow: hidden;
    padding: 0.65rem 0.65rem 0.55rem;
  }

  .gondola {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.6rem;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .gondola::-webkit-scrollbar {
    display: none;
  }

  /* ── Cards ── */
  .gondola-card {
    flex: 0 0 calc(58% - 0.3rem);
    aspect-ratio: 4 / 5;
    scroll-snap-align: start;
    border-radius: var(--radius-sm);
    overflow: hidden;
    position: relative;
  }

  /* image card */
  .gondola-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    border-radius: var(--radius-sm);
  }

  /* text card premium */
  .gondola-text-card {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    padding: 1.1rem 1.15rem;
    background: linear-gradient(
        165deg,
        rgba(255, 255, 255, 0.05) 0%,
        rgba(255, 255, 255, 0.01) 100%
      ),
      rgba(6, 10, 18, 0.94);
    border: 1px solid rgba(159, 241, 255, 0.09);
    border-radius: var(--radius);
    backdrop-filter: blur(28px) saturate(1.3);
    box-shadow:
      0 16px 48px rgba(0, 0, 0, 0.35),
      inset 0 0 0 1px rgba(255, 255, 255, 0.03);
    transition:
      transform 400ms var(--spring),
      border-color 400ms ease;
    cursor: default;
  }

  .gondola-text-card:hover {
    border-color: rgba(159, 241, 255, 0.22);
    transform: translateY(-2px);
  }

  /* Badge System */
  .gondola-badge-shell {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    background: rgba(51, 214, 255, 0.04);
    border: 1px solid rgba(159, 241, 255, 0.12);
    margin-bottom: 1.1rem;
    align-self: flex-start;
  }

  .gondola-tag {
    color: #33d6ff;
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    text-shadow: 0 0 8px rgba(51, 214, 255, 0.35);
  }

  .gondola-badge-line {
    width: 28px;
    height: 1px;
    background: linear-gradient(90deg, rgba(51, 214, 255, 0.4), transparent);
  }

  .gondola-body {
    margin: 0;
    font-size: 0.84rem;
    font-weight: 600;
    color: #e8f4ff;
    line-height: 1.52;
    letter-spacing: -0.01em;
    flex-grow: 1;
    white-space: normal;
  }

  /* Bullet styling inside set:html */
  .gondola-body :global(strong) {
    color: #fff;
    font-weight: 800;
  }

  .gondola-body :global(em) {
    color: #7deaff;
    font-style: normal;
    font-weight: 700;
  }

  .gondola-body :global(br) {
    margin-bottom: 0.4rem;
    display: block;
    content: "";
  }

  .gondola-footer-acc {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.5rem;
    opacity: 0.35;
    transition: opacity 300ms ease;
  }

  .gondola-text-card:hover .gondola-footer-acc {
    opacity: 0.8;
  }

  .gondola-arrow {
    color: #33d6ff;
  }

  /* ── Dots ── */
  .gondola-dots {
    display: flex;
    justify-content: center;
    gap: 0.38rem;
    margin-top: 0.65rem;
  }

  .gondola-dot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.18);
    transition:
      background 200ms ease,
      width 400ms var(--spring);
  }

  .gondola-dot.is-active {
    width: 18px;
    background: #33d6ff;
    box-shadow: 0 0 10px rgba(51, 214, 255, 0.5);
  }

  /* ── Mobile tweaks ── */
  @media (max-width: 640px) {
    .gondola-card {
      flex: 0 0 calc(72% - 0.3rem);
    }
    .gondola-body {
      font-size: 0.8rem;
      line-height: 1.48;
    }
    .gondola-text-card {
      padding: 0.95rem 1rem;
    }
  }
</style>
