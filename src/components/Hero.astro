---
import { Image } from "astro:assets";
import heroLogo from "../assets/neoflowoff_logo.png";
import Gondola from "./Gondola.astro";
---

<section class="section hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <div class="hero-brand-block">
        <Image
          class="hero-logo-sm"
          src={heroLogo}
          alt="NEØ FlowOFF"
          width={88}
          height={88}
          loading="eager"
          fetchpriority="high"
          widths={[120, 200]}
          sizes="96px"
        />
        <div class="hero-brand-divider"></div>
        <a
          href="/"
          class="hero-brand-tag"
          aria-label="NEØ FlowOFF, voltar para a página inicial"
        >
          <span class="hero-brand-neo">NEØ</span>
          <span class="hero-brand-flow">FlowOFF</span>
        </a>
      </div>

      <div class="hero-badge-clean">
        <span class="tech-bracket">[</span> EXPERIMENTE UM WEBAPP <span
          class="tech-bracket">]</span
        >
      </div>

      <h1 aria-label="A maioria dos sites informa. Poucos operam vendas.">
        A maioria dos sites
        <span class="pink-script">informa.</span>
        Poucos
        <span class="acid">operam vendas.</span>
      </h1>

      <p class="hero-lead">
        <span class="hero-lead-core">
          Sua empresa não precisa de mais uma vitrine digital.
        </span>
        <span class="hero-lead-tail">
          Precisa de uma estrutura que capture demanda, organize dados e
          converta intenção em lucro real.
        </span>
      </p>

      <div class="hero-actions">
        <div class="cta-acid-shell">
          <div class="cta-acid-label" aria-hidden="true">
            <span class="cta-acid-dot"></span>
            análise gratuita
          </div>
          <a href="#contato" class="btn btn-primary hero-btn-primary btn-glow">
            <span class="desktop-copy">Solicitar análise</span>
            <span class="mobile-copy">Receber análise</span>
            <svg
              class="hero-btn-icon"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M5 12h14M12 5l7 7-7 7"></path>
            </svg>
          </a>
        </div>
        <a href="#solution" class="btn btn-secondary hero-btn-secondary">
          <svg
            class="hero-btn-icon-left"
            width="15"
            height="15"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <circle cx="12" cy="12" r="10"></circle><path d="M12 8v4l3 3"
            ></path>
          </svg>
          <span class="desktop-copy">Ver como funciona</span>
          <span class="mobile-copy">Ver provas</span>
        </a>
      </div>

      <Gondola />
    </div>
  </div>
</section>

<style>
  /* ── Logo small ── */
  /*
    The source PNG (1024×1024) has ~20% transparent padding on every side.
    At 88px rendered width that's ≈18px of dead space top/bottom.
    Negative margins pull adjacent content back in so the actual glyph
    feels flush — no crop, no background hack needed.
  */
  .hero-hud {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
    font-family: var(--font-mono, monospace);
    font-size: 0.65rem;
    font-weight: 700;
    color: var(--text-4);
    letter-spacing: 0.1em;
  }

  .hero-brand-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    margin-bottom: 1.5rem;
    line-height: 1;
  }

  .hero-brand-neo {
    font-size: 1.7rem;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.04em;
    text-transform: uppercase;
  }

  .hero-brand-flow {
    font-size: 1.7rem;
    font-weight: 800;
    letter-spacing: -0.02em;
    color: #d9ff3f; /* Brand Acid Green - Strong & Technical */
  }

  .hero-badge-clean {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 999px;
    font-family: var(--font-mono, monospace);
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: rgba(255, 255, 255, 0.72);
    margin-bottom: 2rem;
    transition: all 0.3s ease;
  }

  .mobile-copy {
    display: none;
  }

  .desktop-copy {
    display: inline;
  }

  .hero-badge-clean:hover {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.8);
  }

  .hud-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .hud-dot {
    width: 6px;
    height: 6px;
    background: #33d6ff;
    border-radius: 50%;
    box-shadow: 0 0 10px #33d6ff;
    animation: diag-pulse 2s infinite;
  }

  .tech-bracket {
    color: #33d6ff;
    opacity: 0.6;
    font-weight: 400;
  }

  .hero-brand-block {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    margin-bottom: 2.5rem;
  }

  .hero-brand-divider {
    width: 1px;
    height: 28px;
    background: rgba(255, 255, 255, 0.12);
    box-shadow: 1px 0 0 rgba(0, 0, 0, 0.4);
  }

  .hero-logo-sm {
    display: block;
    width: 88px;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: contain;
    margin: 0;
    filter: drop-shadow(0 0 14px rgba(255, 31, 143, 0.22))
      drop-shadow(0 0 24px rgba(51, 214, 255, 0.14));
  }

  /* ── CTA acid container ── */
  .cta-acid-shell {
    position: relative;
    border-radius: 999px;
    padding: 3px;
    background: linear-gradient(
      135deg,
      rgba(217, 255, 63, 0.55) 0%,
      rgba(217, 255, 63, 0.15) 50%,
      rgba(51, 214, 255, 0.18) 100%
    );
    box-shadow:
      0 0 24px rgba(217, 255, 63, 0.18),
      0 0 48px rgba(217, 255, 63, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  /* inner dark fill so the gradient acts as border */
  .cta-acid-shell::before {
    content: "";
    position: absolute;
    inset: 3px;
    border-radius: 999px;
    background: rgba(6, 10, 18, 0.92);
    backdrop-filter: blur(12px);
    z-index: 0;
  }

  .cta-acid-label {
    position: absolute;
    top: -9px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.14rem 0.55rem;
    border-radius: 999px;
    background: rgba(217, 255, 63, 0.12);
    border: 1px solid rgba(217, 255, 63, 0.32);
    backdrop-filter: blur(8px);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(217, 255, 63, 0.85);
    white-space: nowrap;
  }

  .cta-acid-dot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #d9ff3f;
    box-shadow: 0 0 6px rgba(217, 255, 63, 0.9);
    animation: acid-dot-pulse 1.8s ease-in-out infinite;
  }

  @keyframes acid-dot-pulse {
    0%,
    100% {
      opacity: 1;
      box-shadow: 0 0 6px rgba(217, 255, 63, 0.9);
    }
    50% {
      opacity: 0.3;
      box-shadow: none;
    }
  }

  /* button sits above the ::before overlay */
  .cta-acid-shell .btn {
    position: relative;
    z-index: 1;
  }

  @media (max-width: 640px) {
    .desktop-copy {
      display: none;
    }

    .mobile-copy {
      display: inline;
    }

    .hero-brand-block {
      gap: 0.7rem;
      margin-bottom: 1rem;
    }

    .hero-logo-sm {
      width: 72px;
    }

    .hero-brand-neo,
    .hero-brand-flow {
      font-size: 1.45rem;
    }

    .hero-badge-clean {
      display: none;
    }

    .hero-lead-core,
    .hero-lead-tail {
      display: block;
    }

    .hero-lead-tail {
      margin-top: 0.35rem;
      color: var(--text-3);
    }

    .hero-actions {
      gap: 0.4rem;
      margin-bottom: 0.85rem;
    }

    .hero-btn-primary {
      min-height: 58px;
      font-size: 1rem;
    }

    .hero-btn-secondary {
      min-height: 42px;
      justify-content: flex-start;
      padding: 0 0.1rem;
      background: transparent;
      border: 0;
      box-shadow: none;
      color: var(--text-2);
      font-size: 0.84rem;
      opacity: 1;
    }

    .hero-btn-icon-left {
      opacity: 0.9;
    }

    .cta-acid-shell {
      box-shadow:
        0 0 18px rgba(217, 255, 63, 0.16),
        0 0 28px rgba(217, 255, 63, 0.06),
        inset 0 1px 0 rgba(255, 255, 255, 0.08);
    }
  }
</style>
