---
import { Image } from "astro:assets";
import heroLogo from "../assets/neoflowoff_logo.png";
---

<section class="section hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <div class="eyebrow">● EXPERIMENTE UM WEBAPP</div>

      <h1>
        A maioria dos sites
        <span class="pink-script">informa.</span>
        Poucos
        <span class="acid">operam vendas.</span>
      </h1>

      <p class="hero-lead">
        Sua empresa não precisa de mais uma vitrine digital. Precisa de uma
        estrutura que capture demanda, organize dados, revele intenção e ajude o
        comercial a agir no momento certo.
      </p>

      <div class="hero-actions">
        <a href="#form" class="btn btn-primary">Solicitar análise gratuita</a>
        <a href="#solution" class="btn btn-secondary">Ver como funciona</a>
      </div>

      <div class="hero-detail-row">
        <ul class="hero-points">
          <li>Landing pages orientadas à conversão</li>
          <li>WebApps e dashboards comerciais</li>
          <li>Captação, leitura e gestão de leads</li>
          <li>Automações conectadas ao processo de vendas</li>
        </ul>

        <div class="hero-card-wrap">
          <div class="hero-logo-slot">
            <Image
              class="hero-logo-image"
              src={heroLogo}
              alt="NEØ FlowOFF"
              loading="eager"
              widths={[220, 320, 440]}
              sizes="(max-width: 640px) 42vw, 320px"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
