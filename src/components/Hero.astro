---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import heroLogo    from "../assets/neoflowoff_logo.png";
import imgFitness  from "../assets/provas/fitness.png";
import imgPunk     from "../assets/provas/punk-blvck.png";
import imgFlowpay  from "../assets/provas/flowpay.png";
import imgFactory  from "../assets/provas/nsfactory.png";

type ImgSlide  = { type: "img";  src: ImageMetadata; alt: string };
type TextSlide = { type: "text"; tag: string; body: string };
type Slide = ImgSlide | TextSlide;

const slides: Slide[] = [
  { type: "img",  src: imgFitness,  alt: "Fitness webapp" },
  { type: "text", tag: "Landing Page",  body: "Landing pages orientadas à conversão" },
  { type: "img",  src: imgPunk,     alt: "Punk BLVCK webapp" },
  { type: "text", tag: "WebApp",        body: "WebApps e dashboards comerciais" },
  { type: "img",  src: imgFlowpay,  alt: "Flowpay dashboard" },
  { type: "text", tag: "Captação",      body: "Captação, leitura e gestão de leads" },
  { type: "img",  src: imgFactory,  alt: "NS Factory webapp" },
  { type: "text", tag: "Automação",     body: "Automações conectadas ao processo de vendas" },
];
---

<section class="section hero">
  <div class="container hero-grid">
    <div class="hero-copy">
      <Image
        class="hero-logo-sm"
        src={heroLogo}
        alt="NEØ FlowOFF"
        loading="eager"
        widths={[120, 200]}
        sizes="96px"
      />

      <div class="eyebrow">● EXPERIMENTE UM WEBAPP</div>

      <h1>
        A maioria dos sites
        <span class="pink-script">informa.</span>
        Poucos
        <span class="acid">operam vendas.</span>
      </h1>

      <p class="hero-lead">
        Sua empresa não precisa de mais uma vitrine digital. Precisa de uma
        estrutura que capture demanda, organize dados, revele intenção e ajude o
        comercial a agir no momento certo.
      </p>

      <div class="hero-actions">
        <div class="cta-acid-shell">
          <div class="cta-acid-label" aria-hidden="true">
            <span class="cta-acid-dot"></span>
            análise gratuita
          </div>
          <a href="#form" class="btn btn-primary hero-btn-primary">
            Solicitar análise
            <svg class="hero-btn-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>
        <a href="#solution" class="btn btn-secondary hero-btn-secondary">
          <svg class="hero-btn-icon-left" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/>
          </svg>
          Ver como funciona
        </a>
      </div>

      <!-- gondola carousel -->
      <div class="gondola-wrap">
        <div class="gondola-shell">
        <ul class="gondola" id="gondola" aria-label="Serviços em destaque">
          {slides.map((slide, i) => (
            <li class="gondola-card" data-index={i}>
              {slide.type === "img" ? (
                <Image
                  class="gondola-img"
                  src={slide.src}
                  alt={slide.alt}
                  widths={[320, 480]}
                  sizes="280px"
                  loading={i < 2 ? "eager" : "lazy"}
                />
              ) : (
                <div class="gondola-text-card">
                  <span class="gondola-tag">{slide.tag}</span>
                  <p class="gondola-body">{slide.body}</p>
                  <svg class="gondola-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <path d="M7 17L17 7M17 7H7M17 7v10"/>
                  </svg>
                </div>
              )}
            </li>
          ))}
        </ul>
        </div>

        <div class="gondola-dots" aria-hidden="true">
          {slides.map((_, i) => (
            <span class="gondola-dot" data-dot={i}></span>
          ))}
        </div>
      </div>


    </div>
  </div>
</section>

<script is:inline>
  (function () {
    var track  = document.getElementById("gondola");
    var dots   = document.querySelectorAll("[data-dot]");
    if (!track) return;

    var cards    = track.querySelectorAll(".gondola-card");
    var total    = cards.length;
    var current  = 0;
    var timer    = null;
    var paused   = false;

    function cardWidth() {
      return cards[0] ? cards[0].offsetWidth + 12 : 292; /* gap */
    }

    function goTo(idx) {
      current = (idx + total) % total;
      track.scrollTo({ left: current * cardWidth(), behavior: "smooth" });
      dots.forEach(function (d, i) {
        d.classList.toggle("is-active", i === current);
      });
    }

    function next() { if (!paused) goTo(current + 1); }

    function startLoop() {
      clearInterval(timer);
      timer = setInterval(next, 2800);
    }

    /* pause on touch, resume after lift */
    track.addEventListener("touchstart", function () {
      paused = true;
      clearInterval(timer);
    }, { passive: true });

    track.addEventListener("touchend", function () {
      /* sync current index from scroll position */
      setTimeout(function () {
        var idx = Math.round(track.scrollLeft / cardWidth());
        current = (idx + total) % total;
        dots.forEach(function (d, i) { d.classList.toggle("is-active", i === current); });
        paused = false;
        startLoop();
      }, 400);
    }, { passive: true });

    goTo(0);
    startLoop();
  })();
</script>

<style>
  /* ── Logo small ── */
  /*
    The source PNG (1024×1024) has ~20% transparent padding on every side.
    At 88px rendered width that's ≈18px of dead space top/bottom.
    Negative margins pull adjacent content back in so the actual glyph
    feels flush — no crop, no background hack needed.
  */
  .hero-logo-sm {
    display: block;
    width: 88px;
    object-fit: contain;
    margin-top: -16px;
    margin-bottom: calc(0.75rem - 16px);
    filter:
      drop-shadow(0 0 14px rgba(255, 31, 143, 0.22))
      drop-shadow(0 0 24px rgba(51, 214, 255, 0.14));
  }

  /* ── CTA acid container ── */
  .cta-acid-shell {
    position: relative;
    border-radius: 999px;
    padding: 3px;
    background: linear-gradient(
      135deg,
      rgba(217, 255, 63, 0.55) 0%,
      rgba(217, 255, 63, 0.15) 50%,
      rgba(51, 214, 255, 0.18) 100%
    );
    box-shadow:
      0 0 24px rgba(217, 255, 63, 0.18),
      0 0 48px rgba(217, 255, 63, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  /* inner dark fill so the gradient acts as border */
  .cta-acid-shell::before {
    content: "";
    position: absolute;
    inset: 3px;
    border-radius: 999px;
    background: rgba(6, 10, 18, 0.92);
    backdrop-filter: blur(12px);
    z-index: 0;
  }

  .cta-acid-label {
    position: absolute;
    top: -9px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    padding: 0.14rem 0.55rem;
    border-radius: 999px;
    background: rgba(217, 255, 63, 0.12);
    border: 1px solid rgba(217, 255, 63, 0.32);
    backdrop-filter: blur(8px);
    font-size: 0.58rem;
    font-weight: 800;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(217, 255, 63, 0.85);
    white-space: nowrap;
  }

  .cta-acid-dot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: #d9ff3f;
    box-shadow: 0 0 6px rgba(217, 255, 63, 0.9);
    animation: acid-dot-pulse 1.8s ease-in-out infinite;
  }

  @keyframes acid-dot-pulse {
    0%, 100% { opacity: 1;   box-shadow: 0 0 6px rgba(217, 255, 63, 0.9); }
    50%       { opacity: 0.3; box-shadow: none; }
  }

  /* button sits above the ::before overlay */
  .cta-acid-shell .btn {
    position: relative;
    z-index: 1;
  }

  /* ── Gondola wrapper ── */
  .gondola-wrap {
    margin-top: 1.35rem;
    margin-bottom: 0.75rem;
  }

  .gondola-shell {
    border-radius: var(--radius);
    border: 1px solid rgba(51, 214, 255, 0.1);
    background:
      linear-gradient(180deg, rgba(255,255,255,0.04), rgba(255,255,255,0.01)),
      rgba(6, 10, 18, 0.85);
    backdrop-filter: blur(20px) saturate(1.15);
    box-shadow:
      0 12px 32px rgba(0,0,0,0.24),
      inset 0 0 0 1px rgba(255,255,255,0.02);
    overflow: hidden;
    padding: 0.65rem 0.65rem 0.55rem;
  }

  .gondola {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 0.6rem;
    overflow-x: scroll;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
  }

  .gondola::-webkit-scrollbar { display: none; }

  /* ── Cards ── */
  .gondola-card {
    flex: 0 0 calc(58% - 0.3rem);
    aspect-ratio: 4 / 5;
    scroll-snap-align: start;
    border-radius: var(--radius-sm);
    overflow: hidden;
    position: relative;
  }

  /* image card */
  .gondola-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    border-radius: var(--radius-sm);
  }

  /* text card */
  .gondola-text-card {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 1rem 1.05rem;
    background:
      linear-gradient(145deg, rgba(51,214,255,0.1) 0%, rgba(255,31,143,0.06) 100%),
      rgba(6, 10, 18, 0.92);
    border: 1px solid rgba(51, 214, 255, 0.12);
    border-radius: var(--radius);
    backdrop-filter: blur(18px) saturate(1.2);
    box-shadow:
      0 12px 32px rgba(0,0,0,0.28),
      inset 0 1px 0 rgba(255,255,255,0.06);
  }

  .gondola-tag {
    display: inline-block;
    padding: 0.22rem 0.6rem;
    border-radius: 999px;
    background: rgba(51,214,255,0.1);
    border: 1px solid rgba(51,214,255,0.2);
    color: #7deaff;
    font-size: 0.62rem;
    font-weight: 800;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .gondola-body {
    margin: 0;
    font-size: 0.9rem;
    font-weight: 700;
    color: #e8f4ff;
    line-height: 1.38;
    letter-spacing: -0.02em;
  }

  .gondola-arrow {
    align-self: flex-end;
    color: rgba(51,214,255,0.5);
  }

  /* ── Dots ── */
  .gondola-dots {
    display: flex;
    justify-content: center;
    gap: 0.38rem;
    margin-top: 0.65rem;
  }

  .gondola-dot {
    width: 5px;
    height: 5px;
    border-radius: 999px;
    background: rgba(255,255,255,0.18);
    transition: background 200ms ease, width 200ms var(--spring);
  }

  .gondola-dot.is-active {
    width: 18px;
    background: #33d6ff;
    box-shadow: 0 0 8px rgba(51,214,255,0.55);
  }


  /* ── Mobile tweaks ── */
  @media (max-width: 640px) {
    .gondola-card { flex: 0 0 calc(72% - 0.3rem); }
    .gondola-body { font-size: 0.84rem; }
  }
</style>
