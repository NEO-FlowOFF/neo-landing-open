---
import { Image } from "astro:assets";
import founderImg from "../assets/mello.webp";
---

<section class="founder-section" aria-label="Perfil do arquiteto">
  <div class="container">
    <article class="founder-card">
      <div class="founder-media">
        <Image
          class="founder-image"
          src={founderImg}
          alt="NEØ MELLØ"
          width={176}
          height={176}
          loading="lazy"
        />
      </div>

      <div class="founder-copy">
        <p class="founder-kicker">Arquitetura operacional</p>
        <h2>NEØ MELLØ</h2>
        <p class="founder-role">
          <span class="desktop-copy"
            >Programador Full Stack | Gestor de Dados</span
          >
          <span class="mobile-copy">Full Stack | Dados</span>
        </p>
        <p class="founder-text">
          <span class="desktop-copy">
            Expert em Marketing Digital e Blockchain. Arquiteto de sistemas que
            conectam estratégias, tecnologias e resultados reais.
          </span>
          <span class="mobile-copy">
            Arquiteto de sistemas que conectam estratégia, tecnologia e
            resultado real.
          </span>
        </p>
      </div>
    </article>
  </div>
</section>

<style>
  .founder-section {
    position: relative;
    padding: 1.1rem 0 0;
    content-visibility: auto;
    contain-intrinsic-size: 260px;
  }

  .founder-card {
    position: relative;
    display: grid;
    grid-template-columns: 88px minmax(0, 1fr);
    gap: 0.95rem;
    align-items: center;
    padding: 1rem;
    border-radius: var(--radius-lg);
    background:
      linear-gradient(
        180deg,
        rgba(255, 255, 255, 0.05),
        rgba(255, 255, 255, 0.015)
      ),
      rgba(7, 12, 20, 0.72);
    border: 1px solid var(--border-subtle);
    box-shadow:
      0 16px 42px rgba(0, 0, 0, 0.24),
      inset 0 0 0 1px rgba(255, 255, 255, 0.02);
    backdrop-filter: blur(18px) saturate(1.08);
    overflow: hidden;
  }

  .founder-card::after {
    content: "";
    position: absolute;
    right: -24px;
    bottom: -24px;
    width: 132px;
    height: 132px;
    border-radius: 999px;
    background: radial-gradient(
      circle,
      rgba(51, 214, 255, 0.14),
      rgba(255, 31, 143, 0.08) 52%,
      transparent 74%
    );
    filter: blur(12px);
    pointer-events: none;
  }

  .founder-media {
    position: relative;
    z-index: 1;
  }

  .founder-image {
    display: block;
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: var(--radius);
    border: 1px solid rgba(159, 241, 255, 0.08);
    box-shadow:
      0 12px 26px rgba(0, 0, 0, 0.24),
      0 0 20px rgba(51, 214, 255, 0.08);
  }

  .founder-copy {
    position: relative;
    z-index: 1;
    min-width: 0;
  }

  .mobile-copy {
    display: none;
  }

  .founder-kicker {
    margin: 0 0 0.28rem;
    color: #91f2ff;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 800;
    font-size: 0.66rem;
  }

  .founder-copy h2 {
    max-width: none;
    margin-bottom: 0.18rem;
    font-size: clamp(1.15rem, 3vw, 1.55rem);
    line-height: 1;
  }

  .founder-role {
    margin: 0 0 0.35rem;
    color: var(--text-2);
    font-size: 0.88rem;
    font-weight: 600;
    line-height: 1.35;
  }

  .founder-text {
    margin: 0;
    color: var(--text-3);
    font-size: 0.84rem;
    line-height: 1.58;
  }

  /* ─── Responsive ─── */
  @media (max-width: 980px) {
    .founder-card {
      grid-template-columns: 80px minmax(0, 1fr);
      gap: 0.85rem;
    }
  }

  @media (max-width: 640px) {
    .founder-section {
      padding-top: 0.9rem;
    }

    .founder-card {
      grid-template-columns: 72px minmax(0, 1fr);
      gap: 0.75rem;
      padding: 0.85rem;
      border-radius: var(--radius);
    }

    .founder-image {
      border-radius: var(--radius-sm);
    }
    .founder-kicker {
      font-size: 0.6rem;
      letter-spacing: 0.12em;
    }
    .founder-copy h2 {
      font-size: 1.05rem;
    }
    .founder-role {
      font-size: 0.8rem;
    }

    .founder-text {
      font-size: 0.78rem;
      line-height: 1.5;
    }

    .desktop-copy {
      display: none;
    }

    .mobile-copy {
      display: inline;
    }
  }
</style>
