---
const web3formsAccessKey = import.meta.env.WEB3FORMS_ACCESS_KEY ?? "";
---

<div class="analysis-form-wrapper">
  <form
    id="modal-form"
    class="lead-form"
    action="https://api.web3forms.com/submit"
    method="POST"
  >
    <input type="hidden" name="access_key" value={web3formsAccessKey} />
    <input type="hidden" name="subject" value="Novo lead - FlowOFF" />
    <input type="hidden" name="from_name" value="LP FlowOFF" />

    <!-- anti-spam -->
    <input type="checkbox" name="botcheck" style="display: none;" />

    <input type="hidden" name="utm_source" id="m-utm_source" />
    <input type="hidden" name="utm_campaign" id="m-utm_campaign" />
    <input type="hidden" name="utm_content" id="m-utm_content" />
    <input type="hidden" name="referrer" id="m-referrer" />
    <input type="hidden" name="timestamp" id="m-timestamp" />

    <div class="field">
      <label for="m-nome">Nome</label>
      <input id="m-nome" name="nome" required placeholder="Seu nome" />
    </div>

    <div class="field">
      <label for="m-empresa">Empresa</label>
      <input id="m-empresa" name="empresa" required placeholder="Sua empresa" />
    </div>

    <div class="field">
      <label for="m-funcionarios">Funcionários</label>
      <select id="m-funcionarios" name="funcionarios" required>
        <option value="">Selecione</option>
        <option>1 a 6</option>
        <option>7 a 15</option>
        <option>16 a 30</option>
        <option>31+</option>
      </select>
    </div>

    <div class="field">
      <label for="m-site">Site</label>
      <input id="m-site" name="site" type="url" placeholder="https://" />
    </div>

    <div class="field">
      <label for="m-whatsapp">WhatsApp</label>
      <input
        id="m-whatsapp"
        name="whatsapp"
        required
        placeholder="(00) 00000-0000"
      />
    </div>

    <div class="field field-full">
      <label for="m-objetivo">Objetivo</label>
      <textarea
        id="m-objetivo"
        name="objetivo"
        placeholder="Como podemos ajudar?"></textarea>
    </div>

    <button type="submit" class="btn btn-primary btn-full btn-glow">
      Receber análise gratuita
    </button>
  </form>
</div>

<script is:inline>
  (function () {
    const form = document.getElementById("modal-form");
    if (!form) return;

    const params = new URLSearchParams(window.location.search);
    const sourceEl = document.getElementById("m-utm_source");
    if (sourceEl) sourceEl.value = params.get("utm_source") || "";

    const campEl = document.getElementById("m-utm_campaign");
    if (campEl) campEl.value = params.get("utm_campaign") || "";

    const contEl = document.getElementById("m-utm_content");
    if (contEl) contEl.value = params.get("utm_content") || "";

    const refEl = document.getElementById("m-referrer");
    if (refEl) refEl.value = document.referrer;

    const timeEl = document.getElementById("m-timestamp");
    if (timeEl) timeEl.value = new Date().toISOString();

    form.addEventListener("submit", async function (e) {
      e.preventDefault();
      const submitBtn = form.querySelector('button[type="submit"]');
      if (submitBtn) submitBtn.disabled = true;

      const data = new FormData(form);
      try {
        const response = await fetch(form.action, {
          method: "POST",
          body: data,
        });
        if (response.ok) {
          // Track conversion in Meta
          if (typeof fbq === "function") {
            fbq("track", "Lead");
          }
          form.innerHTML =
            "<div class='form-success'><p>Recebido. Nossa IA e time técnico já estão analisando seu ecossistema.</p></div>";
        } else {
          throw new Error();
        }
      } catch (err) {
        if (submitBtn) submitBtn.disabled = false;
        alert("Erro ao enviar. Tente novamente.");
      }
    });
  })();
</script>

<style>
  .lead-form {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    padding: 1rem 0;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .field-full {
    grid-column: 1 / -1;
  }

  label {
    font-size: 0.85rem;
    color: var(--text-3);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  input,
  select,
  textarea {
    width: 100%;
    appearance: none;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.3);
    color: #fff;
    border-radius: 8px;
    padding: 0.8rem 1rem;
    outline: none;
    font: inherit;
    font-size: 0.95rem;
    transition: all 0.2s;
  }

  input:focus,
  select:focus,
  textarea:focus {
    border-color: #ff1f8f;
    background: rgba(255, 31, 143, 0.05);
  }

  .form-success {
    text-align: center;
    padding: 2rem;
    color: #d9ff3f;
    font-weight: 700;
  }

  @media (max-width: 640px) {
    .lead-form {
      grid-template-columns: 1fr;
    }
  }
</style>
