---
const raw = import.meta.env.WATTSAPP_NUMBER ?? "";
const number = raw.replace(/\D/g, "");
const waHref = number
  ? `https://wa.me/55${number}?text=Ol%C3%A1!%20Vi%20o%20site%20da%20FlowOFF%20e%20quero%20receber%20uma%20an%C3%A1lise%20gratuita.`
  : "#";
---

<div class="sticky-bar" id="sticky-bar" aria-label="Ação rápida">
  {waHref !== "#" && (
    <a
      href={waHref}
      class="sticky-wa"
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Falar no WhatsApp"
    >
      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
      </svg>
      WhatsApp
    </a>
  )}

  <a href="#form" class="sticky-cta" id="sticky-scroll-cta">
    Solicitar análise gratuita
  </a>
</div>

<script is:inline>
  (function () {
    var bar  = document.getElementById("sticky-bar");
    var form = document.getElementById("form");

    function update() {
      if (!bar) return;
      var scrolled = window.scrollY > 100;
      var formVisible = false;
      if (form) {
        var rect = form.getBoundingClientRect();
        formVisible = rect.top < window.innerHeight * 0.8 && rect.bottom > 0;
      }
      bar.classList.toggle("is-visible", scrolled && !formVisible);
    }

    update();
    window.addEventListener("scroll", update, { passive: true });
    window.addEventListener("resize", update, { passive: true });

    var scrollBtn = document.getElementById("sticky-scroll-cta");
    if (scrollBtn) {
      scrollBtn.addEventListener("click", function (e) {
        if (!form) return;
        e.preventDefault();
        form.scrollIntoView({ behavior: "smooth", block: "start" });
        var first = form.querySelector("input:not([type=hidden])");
        if (first) setTimeout(function () { first.focus(); }, 400);
      });
    }
  })();
</script>

<style>
  /* Hidden on desktop — shown only on mobile via .is-visible */
  .sticky-bar {
    display: none;
  }

  @media (max-width: 640px) {
    .sticky-bar {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 60;
      padding: 0.75rem 1rem calc(env(safe-area-inset-bottom, 0px) + 0.75rem);
      background:
        linear-gradient(
          0deg,
          rgba(4, 6, 12, 0.98) 0%,
          rgba(6, 9, 18, 0.9) 100%
        );
      border-top: 1px solid rgba(159, 241, 255, 0.1);
      backdrop-filter: blur(24px) saturate(1.35);
      box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.32);
      transform: translateY(110%);
      transition: transform 300ms var(--spring);
      will-change: transform;
    }

    .sticky-bar.is-visible {
      transform: translateY(0);
    }

    .sticky-wa {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      min-height: 52px;
      padding: 0 1rem;
      border-radius: var(--radius-sm);
      background: #25d366;
      color: #fff;
      font-weight: 800;
      font-size: 0.86rem;
      text-decoration: none;
      white-space: nowrap;
      box-shadow:
        0 8px 22px rgba(37, 211, 102, 0.32),
        inset 0 1px 0 rgba(255, 255, 255, 0.22);
      transition:
        transform 160ms var(--spring),
        box-shadow 160ms var(--ease-out);
    }

    .sticky-wa:active { transform: scale(0.95); }

    .sticky-cta {
      flex: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 52px;
      border-radius: var(--radius-sm);
      background: linear-gradient(135deg, var(--acid) 0%, #c3ff2b 100%);
      color: #0a0d14;
      font-weight: 800;
      font-size: 0.88rem;
      text-decoration: none;
      text-align: center;
      white-space: nowrap;
      box-shadow:
        0 8px 22px rgba(164, 209, 32, 0.22),
        inset 0 1px 0 rgba(255, 255, 255, 0.24);
      transition:
        transform 160ms var(--spring),
        box-shadow 160ms var(--ease-out);
    }

    .sticky-cta:active { transform: scale(0.95); }
  }
</style>
