---
const raw = import.meta.env.WATTSAPP_NUMBER ?? "";
const number = raw.replace(/\D/g, "");
const waHref = number
  ? `https://wa.me/55${number}?text=Olá!%20Vi%20o%20site%20da%20NEØ%20FlowOFF%20e%20quero%20receber%20uma%20análise%20gratuita.`
  : "#";
---

<div class="sticky-bar" id="sticky-bar" aria-label="Ação rápida">
  {
    waHref !== "#" && (
      <a
        href={waHref}
        class="sticky-wa"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Falar no WhatsApp"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
        </svg>
        <span class="sticky-wa-label">WhatsApp</span>
      </a>
    )
  }

  <a href="#contato" class="sticky-cta" id="sticky-scroll-cta">
    <span class="sticky-cta-main">Receber diagnóstico</span>
    <span class="sticky-cta-sub">leitura inicial</span>
  </a>
</div>

<script is:inline>
  (function () {
    const bar = document.getElementById("sticky-bar");
    const form = document.getElementById("form");

    let formTop = 0;
    let formHeight = 0;
    let isTicking = false;

    const cacheFormPosition = () => {
      if (!form) return;
      let top = 0;
      let curr = form;
      while (curr) {
        top += curr.offsetTop;
        curr = curr.offsetParent;
      }
      formTop = top;
      formHeight = form.offsetHeight;
    };

    const update = () => {
      if (!bar) {
        isTicking = false;
        return;
      }
      const y = window.scrollY;
      const scrolled = y > 48;
      let formVisible = false;

      if (form) {
        const viewportHeight = window.innerHeight;
        formVisible =
          formTop < y + viewportHeight * 0.8 && formTop + formHeight > y;
      }

      bar.classList.toggle("is-visible", scrolled && !formVisible);
      isTicking = false;
    };

    const onScroll = () => {
      if (!isTicking) {
        requestAnimationFrame(update);
        isTicking = true;
      }
    };

    cacheFormPosition();
    update();

    window.addEventListener("scroll", onScroll, { passive: true });
    window.addEventListener(
      "resize",
      () => {
        cacheFormPosition();
        onScroll();
      },
      { passive: true },
    );

    // Scroll logic was replaced by global AnalysisModal trigger

    document.addEventListener("astro:after-swap", () => {
      cacheFormPosition();
      update();
    });
  })();
</script>

<style>
  /* Hidden on desktop — shown only on mobile via .is-visible */
  .sticky-bar {
    display: none;
  }

  @media (max-width: 640px) {
    .sticky-bar {
      display: flex;
      align-items: center;
      gap: 0.65rem;
      position: fixed;
      bottom: 0;
      left: 0;
      right: 0;
      z-index: 60;
      padding: 0.75rem 1rem calc(env(safe-area-inset-bottom, 0px) + 0.75rem);
      background: linear-gradient(
        0deg,
        rgba(4, 6, 12, 0.98) 0%,
        rgba(6, 9, 18, 0.9) 100%
      );
      border-top: 1px solid rgba(159, 241, 255, 0.1);
      backdrop-filter: blur(24px) saturate(1.35);
      box-shadow: 0 -8px 32px rgba(0, 0, 0, 0.32);
      transform: translateY(110%);
      transition: transform 300ms var(--spring);
      will-change: transform;
    }

    .sticky-bar.is-visible {
      transform: translateY(0);
    }

    .sticky-wa {
      flex: 0 0 auto;
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      min-height: 52px;
      padding: 0 1rem;
      border-radius: var(--radius-sm);
      background: #25d366;
      color: #fff;
      font-weight: 800;
      font-size: 0.86rem;
      text-decoration: none;
      white-space: nowrap;
      box-shadow:
        0 8px 22px rgba(37, 211, 102, 0.32),
        inset 0 1px 0 rgba(255, 255, 255, 0.22);
      transition:
        transform 160ms var(--spring),
        box-shadow 160ms var(--ease-out);
    }

    .sticky-wa-label {
      display: none;
    }

    .sticky-wa:active {
      transform: scale(0.95);
    }

    .sticky-cta {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      justify-content: center;
      min-height: 56px;
      border-radius: var(--radius-sm);
      background: linear-gradient(135deg, var(--acid) 0%, #c3ff2b 100%);
      color: #0a0d14;
      font-weight: 800;
      font-size: 0.92rem;
      text-decoration: none;
      text-align: left;
      box-shadow:
        0 8px 22px rgba(164, 209, 32, 0.22),
        inset 0 1px 0 rgba(255, 255, 255, 0.24);
      transition:
        transform 160ms var(--spring),
        box-shadow 160ms var(--ease-out);
    }

    .sticky-cta-main {
      display: block;
      line-height: 1.05;
    }

    .sticky-cta-sub {
      display: block;
      margin-top: 0.15rem;
      font-size: 0.66rem;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: rgba(10, 13, 20, 0.72);
    }

    .sticky-cta:active {
      transform: scale(0.95);
    }
  }
</style>
