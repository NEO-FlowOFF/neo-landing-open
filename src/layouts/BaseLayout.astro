---
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import StickyBar from "../components/StickyBar.astro";
import AnalysisModal from "../components/AnalysisModal.astro";
import Schema from "../components/Schema.astro";
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  robots?: string;
}

const {
  title = "NEØ FlowOFF | Sites que operam vendas",
  description = "Landing pages, webapps, dashboards e automações para transformar presença digital em aquisição de clientes.",
  ogImage = "/assets/og-flowoff.png",
  robots = "index,follow",
} = Astro.props;

const canonicalUrl = new URL(
  Astro.url.pathname,
  Astro.site ?? Astro.url,
).toString();
const ogImageUrl = new URL(ogImage, Astro.site ?? Astro.url).toString();
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="facebook-domain-verification"
      content="z2xcysmhxt1up1u02q6tdp1nvrd3pw"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <meta name="theme-color" content="#ff1f8f" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta
      name="apple-mobile-web-app-status-bar-style"
      content="black-translucent"
    />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="pt-br" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    <link rel="icon" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content="FlowOFF" />
    <meta property="og:locale" content="pt_BR" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <ClientRouter />
    <Schema description={description} />

    <!-- Meta Pixel Code -->
    <script is:inline>
      // 1. Inicialização Padrão do Pixel
      !(function (f, b, e, v, n, t, s) {
        if (f.fbq) return;
        n = f.fbq = function () {
          n.callMethod
            ? n.callMethod.apply(n, arguments)
            : n.queue.push(arguments);
        };
        if (!f._fbq) f._fbq = n;
        n.push = n;
        n.loaded = !0;
        n.version = "2.0";
        n.queue = [];
        t = b.createElement(e);
        t.async = !0;
        t.src = v;
        s = b.getElementsByTagName(e)[0];
        s.parentNode.insertBefore(t, s);
      })(
        window,
        document,
        "script",
        "https://connect.facebook.net/en_US/fbevents.js",
      );

      fbq("init", "1646739783423680");

      // 2. NΞØ-Bridge Configuration 🛰️
      const NEO_NODE_URL = "https://sites.neoflowoff.agency";
      const NEO_IS_LOCAL_PREVIEW = ["localhost", "127.0.0.1", "[::1]"].includes(
        window.location.hostname,
      );

      window.NeoBridge = {
        get_meta_cookies() {
          const getCookie = (name) => {
            const value = `; ${document.cookie}`;
            const parts = value.split(`; ${name}=`);
            if (parts.length === 2) return parts.pop().split(";").shift();
          };
          return { fbp: getCookie("_fbp"), fbc: getCookie("_fbc") };
        },

        generate_event_id() {
          return (
            "neo_" + Math.random().toString(36).slice(2, 11) + "_" + Date.now()
          );
        },

        async track(eventName, userData = {}, customData = {}) {
          const eventId = this.generate_event_id();
          const cookies = this.get_meta_cookies();

          const payload = {
            event_name: eventName,
            event_id: eventId,
            event_time: Math.floor(Date.now() / 1000),
            user_data: {
              ...cookies,
              client_user_agent: navigator.userAgent,
              fbp: cookies.fbp,
              fbc: cookies.fbc,
              ...userData,
            },
            custom_data: customData,
          };

          try {
            if (!NEO_IS_LOCAL_PREVIEW) {
              await fetch(`${NEO_NODE_URL}/api/event`, {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(payload),
                keepalive: true,
              });
            }

            // SINAL 2: Pixel (Via Navegador) 🟢
            if (typeof fbq !== "undefined") {
              fbq("track", eventName, { ...customData, eventID: eventId });
            }
            if (!NEO_IS_LOCAL_PREVIEW) {
              console.log(
                `[NΞØ] Evento ${eventName} disparado com Duplo Sinal!`,
              );
            }
          } catch (e) {
            if (!NEO_IS_LOCAL_PREVIEW) {
              console.error("[NΞØ] Falha técnica no rastreamento:", e);
            }
          }
        },
      };

      NeoBridge.track("PageView");
    </script>

    <noscript>
      <img
        height="1"
        width="1"
        style="display:none"
        src="https://www.facebook.com/tr?id=1646739783423680&ev=PageView&noscript=1"
      />
    </noscript>

    <!-- End Meta Pixel Code -->

    <!-- Critical path CSS to avoid render blocking (1,480ms savings) -->
    <style is:inline>
      :root {
        --bg: #06070c;
        --text: #f5f7fb;
        --pink: #ff1f8f;
        --cyan: #33d6ff;
        --acid: #d9ff3f;
        --ease-out: cubic-bezier(0.2, 0, 0, 1);
        --spring: cubic-bezier(0.34, 1.2, 0.64, 1);
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--text);
        font-family: system-ui, sans-serif;
        overflow-x: hidden;
      }
      .page-noise {
        position: fixed;
        inset: 0;
        pointer-events: none;
        opacity: 0.08;
        background-size: 32px 32px;
        mask-image: radial-gradient(
          circle at center,
          black 45%,
          transparent 100%
        );
      }
      [data-site-header] {
        opacity: 0;
        transform: translateY(-10px);
      }
      [data-site-header].is-scrolled,
      [data-site-header]:not(.is-scrolled) {
        opacity: 1;
        transform: translateY(0);
        transition:
          opacity 380ms var(--ease-out),
          transform 380ms var(--ease-out);
      }
    </style>

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="preconnect"
      href="https://fonts.gstatic.com"
      crossorigin
      fetchpriority="high"
    />
    <link
      rel="preload"
      as="style"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
      rel="stylesheet"
      media="print"
      onload="this.setAttribute('media', 'all')"
    />
    <noscript>
      <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
        rel="stylesheet"
      />
    </noscript>
  </head>
  <body>
    <div class="page-noise"></div>
    <div class="page-glow page-glow-pink"></div>
    <div class="page-glow page-glow-yellow"></div>
    <Header />
    <slot />
    <Footer />
    <StickyBar />
    <AnalysisModal />
  </body>
</html>
